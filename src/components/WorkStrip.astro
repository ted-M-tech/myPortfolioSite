---
import { projects } from "../data/profile";
import ProjectPanel from "./ProjectPanel.astro";

/**
 * 作品の横流し一覧。2列を逆方向に、継ぎ目なく流し続ける。
 *
 * 縦積みのカードは一度に1件しか見えない。全件を面として見せるのがこの帯の役目。
 *
 * 実装は CSS アニメーションだけ。同じ並びを2回描いて -50% まで動かすと、
 * 折り返した瞬間に絵が元の位置と一致するので、ループの継ぎ目が出ない。
 * スクロール連動も試したが、上下に間隔さえ取れば流し続けて問題ないので、
 * JS の依存を持たない方を選んだ。
 *
 * 上下で並び順を変え、速度も少しずらしているのは、2列が一枚の板のように
 * 固まって動いて見えないようにするため。
 *
 * ホバーで止めない。個々の案件を読ませる場所ではなく、量を伝える場所で、
 * 詳細は下の縦積みカードが受け持つ。だから aria-hidden で読み上げからも外す。
 */
const rowA = projects.map((p, i) => ({ p, i }));
const rowB = [...rowA].reverse();
---

<div class="strip" aria-hidden="true">
  <div class="row">
    <div class="track track--left">
      {
        [0, 1].map(() => (
          <div class="run">
            {rowA.map(({ p, i }) => (
              <article class="card">
                <div class="thumb">
                  <ProjectPanel index={i} animate={false} />
                </div>
                <p class="title">
                  <span class="ja">{p.title.ja}</span>
                  <span class="en">{p.title.en}</span>
                </p>
                <p class="role">
                  <span class="ja">{p.role.ja}</span>
                  <span class="en">{p.role.en}</span>
                </p>
              </article>
            ))}
          </div>
        ))
      }
    </div>
  </div>

  <div class="row">
    <div class="track track--right">
      {
        [0, 1].map(() => (
          <div class="run">
            {rowB.map(({ p, i }) => (
              <article class="card">
                <div class="thumb">
                  <ProjectPanel index={i} animate={false} />
                </div>
                <p class="title">
                  <span class="ja">{p.title.ja}</span>
                  <span class="en">{p.title.en}</span>
                </p>
                <p class="role">
                  <span class="ja">{p.role.ja}</span>
                  <span class="en">{p.role.en}</span>
                </p>
              </article>
            ))}
          </div>
        ))
      }
    </div>
  </div>

  <!-- 端を地の色に溶かす。切り落としに見せないための覆い -->
  <div class="fade"></div>
</div>

<style>
  .strip {
    position: relative;
    /*
     * 上下に間隔を取る。流れ続けるものが読んでいる本文のすぐ隣にあると
     * 気が散るが、離してしまえば「奥で動いている」だけになる。
     */
    margin-block: clamp(48px, 6vw, 88px);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .row {
    overflow: hidden;
  }

  .track {
    display: flex;
    width: max-content;
  }

  .run {
    display: flex;
    gap: 16px;
    padding-right: 16px;
  }

  /* 同じ並びを2つ描いて -50% まで動かすと、継ぎ目が出ない */
  .track--left {
    animation: rail-left 24s linear infinite;
  }
  .track--right {
    animation: rail-right 29s linear infinite;
  }

  @keyframes rail-left {
    to {
      transform: translateX(-50%);
    }
  }
  @keyframes rail-right {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }

  .card {
    flex: none;
    width: clamp(210px, 19vw, 268px);
  }

  .thumb {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
  }

  .title {
    margin-top: 12px;
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    /* 題名が折り返すと列の高さが揃わなくなる */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .role {
    margin-top: 2px;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .fade {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      to right,
      var(--surface) 0%,
      transparent 14%,
      transparent 86%,
      var(--surface) 100%
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
    }
    /* 止めるなら自分で送れるようにする。1列あれば足りる */
    .row {
      overflow-x: auto;
    }
    .row + .row {
      display: none;
    }
    .fade {
      display: none;
    }
  }
</style>

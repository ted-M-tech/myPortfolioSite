---
import { marquee } from "../data/profile";
import Icon from "./Icon.astro";

type StackLabel = (typeof marquee)[number];
type StackIcon = "brain" | "code" | "database" | "cloud";

const genericIcons: Partial<Record<StackLabel, StackIcon>> = {
  "AI Driven Development": "brain",
  "Generative AI": "brain",
  "Full Stack": "code",
  "API Design": "code",
  "Real-time Data": "database",
  "Cloud Architecture": "cloud",
  "Rapid Prototyping": "code",
  "DevOps": "cloud",
};

const brandIcons: Partial<Record<StackLabel, string>> = {
  "Next.js": "/brand/stack/nextjs.svg",
};

const row = marquee.map((label) => ({
  label,
  icon: genericIcons[label],
  brand: brandIcons[label],
}));
const reversed = [...row].reverse();
---

<!--
  2本の帯を逆向きに流す。上は袋文字（輪郭だけ）、下は塗りを薄く落とす。
  奥行きが出て、単なる文字列の羅列に見えなくなる。
-->
<div class="marq" aria-hidden="true">
  <div class="track">
    {
      [0, 1].map(() => (
        <span class="run">
          {row.map((item) => (
            <span class="item">
              {
                item.brand
                  ? <img class="brand-icon" src={item.brand} alt="" width="38" height="38" />
                  : item.icon
                    ? <span class="stack-icon"><Icon name={item.icon} size={34} /></span>
                    : null
              }
              <span>{item.label}</span>
              <i class="separator">·</i>
            </span>
          ))}
        </span>
      ))
    }
  </div>
</div>

<div class="marq marq--rev" aria-hidden="true">
  <div class="track track--sub">
    {
      [0, 1].map(() => (
        <span class="run">
          {reversed.map((item) => (
            <span class="item">
              {
                item.brand
                  ? <img class="brand-icon" src={item.brand} alt="" width="38" height="38" />
                  : item.icon
                    ? <span class="stack-icon"><Icon name={item.icon} size={34} /></span>
                    : null
              }
              <span>{item.label}</span>
              <i class="separator">·</i>
            </span>
          ))}
        </span>
      ))
    }
  </div>
</div>

<style>
  .marq {
    background: var(--surface-dark-2);
    color: var(--text-on-dark);
    overflow: hidden;
    padding-block: 18px 0;
  }

  .marq:first-of-type {
    border-top: 1px solid var(--line-on-dark);
    padding-top: 30px;
  }

  .marq--rev {
    padding-bottom: 30px;
    border-bottom: 1px solid var(--line-on-dark);
  }

  .track {
    display: flex;
    width: max-content;
    animation: slide 27s linear infinite;
  }

  .marq--rev .track {
    animation-direction: reverse;
  }

  .track--sub {
    opacity: 0.34;
  }

  .run {
    display: flex;
  }

  .item {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding-right: 34px;
    font-size: clamp(28px, 4.4vw, 52px);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    white-space: nowrap;
    /* 上の列は輪郭だけ。塗りを抜いて袋文字にする */
    -webkit-text-stroke: 1px rgba(243, 240, 235, 0.5);
    color: transparent;
  }

  .brand-icon,
  .stack-icon {
    flex: 0 0 auto;
    width: clamp(24px, 2.5vw, 38px);
    height: clamp(24px, 2.5vw, 38px);
    -webkit-text-stroke: 0;
  }

  .brand-icon {
    object-fit: contain;
  }

  .stack-icon {
    display: grid;
    place-items: center;
    color: rgba(243, 240, 235, 0.66);
  }

  .stack-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* 下の列は塗る。輪郭と塗りが交互になって帯にリズムが出る */
  .track--sub .item {
    -webkit-text-stroke: 0;
    color: var(--text-on-dark);
  }

  .separator {
    margin-left: 22px;
    font-style: normal;
    -webkit-text-stroke: 0;
    color: var(--accent-on-dark);
  }

  @keyframes slide {
    to {
      transform: translateX(-50%);
    }
  }

  .marq:hover .track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
    }
  }
</style>

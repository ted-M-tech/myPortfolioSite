---
const steps = [
  {
    no: "01",
    en: "Frame",
    ja: "芯を見つける",
    bodyJa: "誰の、どんな課題を解くのか。事業・ユーザー・データの接点から、最初に検証すべき仮説を定めます。",
    bodyEn: "Define the user, the problem and the first hypothesis worth testing across business, workflow and data.",
    output: "PROBLEM / SCOPE / ARCHITECTURE",
  },
  {
    no: "02",
    en: "Prototype",
    ja: "早く、触れる",
    bodyJa: "AIを使って動く検証版を素早くつくり、技術的な実現性とユーザー価値を同時に確かめます。",
    bodyEn: "Use AI to build a working prototype quickly and test technical feasibility alongside user value.",
    output: "AI POC / DATA FLOW / WORKING UI",
  },
  {
    no: "03",
    en: "Craft",
    ja: "細部まで、つくる",
    bodyJa: "フロントエンド、API、データ、認証、クラウドを、一貫した設計と本番品質のコードへ落とし込みます。",
    bodyEn: "Engineer frontend, APIs, data, authentication and cloud as one production-ready system.",
    output: "FRONTEND / BACKEND / CLOUD",
  },
  {
    no: "04",
    en: "Launch",
    ja: "公開して、育てる",
    bodyJa: "速さ・アクセシビリティ・計測を整えて公開。反応を見ながら、次の一歩へ改善します。",
    bodyEn: "Launch with speed, accessibility and measurement in place, then improve from real behavior.",
    output: "QA / RELEASE / ITERATION",
  },
] as const;
---

<section class="process section" id="process">
  <div class="wrap layout">
    <header class="reveal">
      <p class="eyebrow">From idea to impact / 06</p>
      <h2 class="section-title">
        <span class="ja">AIで、開発を前へ。</span>
        <span class="en">Move development forward with AI.</span>
      </h2>
      <p class="section-lede">
        <span class="ja">
          AIで速く試し、フルスタックで最後までつくる。課題設定から本番運用、公開後の改善まで一気通貫で。
        </span>
        <span class="en">
          Use AI to validate faster, then full-stack ownership to carry the product through production and iteration.
        </span>
      </p>
    </header>

    <ol>
      {steps.map((step) => (
        <li class="reveal">
          <span class="no">{step.no}</span>
          <div class="title">
            <p>{step.en}</p>
            <h3 class="ja">{step.ja}</h3>
            <h3 class="en">{step.en}</h3>
          </div>
          <p class="body">
            <span class="ja">{step.bodyJa}</span>
            <span class="en">{step.bodyEn}</span>
          </p>
          <span class="output">{step.output}</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process { background: var(--surface); }

  .layout {
    display: grid;
    grid-template-columns: .82fr 1.18fr;
    gap: clamp(56px, 8vw, 132px);
    align-items: start;
  }

  header {
    position: sticky;
    top: 128px;
  }

  ol { border-top: 1px solid var(--line-strong); }

  li {
    display: grid;
    grid-template-columns: 42px minmax(130px, .75fr) 1.3fr;
    gap: 22px;
    padding-block: 30px 34px;
    border-bottom: 1px solid var(--line-strong);
  }

  .no, .output, .title > p {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: .12em;
  }

  .no, .title > p { color: var(--text-faint); }

  .title > p {
    margin-bottom: 7px;
    text-transform: uppercase;
  }

  h3 {
    font-size: clamp(22px, 2.2vw, 34px);
    font-weight: 550;
    line-height: 1.1;
    letter-spacing: var(--tracking-display);
  }

  .body {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-muted);
    text-wrap: pretty;
  }

  .output {
    grid-column: 2 / -1;
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .layout { grid-template-columns: 1fr; }
    header { position: static; }
  }

  @media (max-width: 620px) {
    li {
      grid-template-columns: 32px 1fr;
      gap: 14px;
    }
    .body, .output { grid-column: 2; }
  }
</style>

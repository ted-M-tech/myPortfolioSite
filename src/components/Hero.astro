---
import { person } from "../data/profile";
import Icon from "./Icon.astro";
---

<section class="hero on-dark" id="top">
  <canvas id="hero-shader" aria-hidden="true"></canvas>
  <div class="noise" aria-hidden="true"></div>

  <div class="hero-grid">
    <div class="hero-copy">
      <p class="status">
        <i aria-hidden="true"></i>
        <span class="ja">2026年 秋以降のプロジェクト受付中</span>
        <span class="en">Booking projects from Fall 2026</span>
      </p>

      <p class="kicker">
        <span class="ja">{person.role.ja} / {person.location.ja}</span>
        <span class="en">{person.role.en} / {person.location.en}</span>
      </p>

      <h1>
        <span class="ja" set:html={person.headline.ja} />
        <span class="en" set:html={person.headline.en} />
      </h1>

      <p class="intro">
        <span class="ja">{person.intro.ja}</span>
        <span class="en">{person.intro.en}</span>
      </p>

      <div class="actions">
        <a href="#work" class="btn btn--light">
          <span class="ja">制作を見る</span>
          <span class="en">Explore the work</span>
          <Icon name="arrow-right" size={17} />
        </a>
        <a href="#contact" class="text-link">
          <span class="ja">プロジェクトを相談</span>
          <span class="en">Start a project</span>
          <Icon name="arrow-up-right" size={15} />
        </a>
      </div>
    </div>

    <div class="spatial-labels" aria-hidden="true">
      <span class="label label--ai">RAW SIGNALS <i>∞</i></span>
      <span class="label label--motion">POINT OF VIEW <i>01</i></span>
      <span class="label label--three">NEXT STEP <i>→</i></span>
      <span class="axis">AI INPUTS / FULL STACK<br />1 PRODUCTION SYSTEM</span>
    </div>
  </div>

  <div class="hero-foot">
    <p>MAEPACE® / INDEPENDENT AI DRIVEN DEVELOPMENT</p>
    <a href="#work">
      <span class="ja">スクロールして体験</span>
      <span class="en">Scroll to experience</span>
      <Icon name="chevron-down" size={18} />
    </a>
    <p>VANCOUVER / JAPAN</p>
  </div>
</section>

<script>
  import { initHeroShader } from "../scripts/hero-shader";

  const canvas = document.getElementById("hero-shader");
  if (canvas instanceof HTMLCanvasElement) initHeroShader(canvas);
</script>

<style>
  .hero {
    position: relative;
    min-height: max(760px, 100svh);
    overflow: hidden;
    isolation: isolate;
    background: #090807;
    color: var(--text-on-dark);
  }

  #hero-shader {
    position: absolute;
    inset: 0;
    z-index: -3;
    width: 100%;
    height: 100%;
  }

  .noise {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    opacity: 0.11;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.32'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(7, 6, 5, 0.84) 0%, rgba(7, 6, 5, 0.38) 43%, transparent 68%),
      linear-gradient(0deg, rgba(7, 6, 5, 0.66), transparent 30%);
  }

  .hero-grid {
    min-height: max(760px, 100svh);
    padding: clamp(130px, 16vh, 180px) var(--pad-x) 112px;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
    align-items: center;
    max-width: 1840px;
    margin-inline: auto;
  }

  .hero-copy {
    position: relative;
    z-index: 3;
    max-width: 880px;
    opacity: 0;
    transform: translateY(28px);
    animation: enter 1.1s var(--ease-out) 0.14s forwards;
  }

  @keyframes enter {
    to { opacity: 1; transform: none; }
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 7px 12px;
    border: 1px solid rgba(243, 240, 235, 0.16);
    border-radius: var(--radius-pill);
    background: rgba(10, 9, 8, 0.3);
    backdrop-filter: blur(14px);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(243, 240, 235, 0.74);
  }

  .status i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #7cff9d;
    box-shadow: 0 0 14px #7cff9d;
    animation: pulse 2.2s ease-in-out infinite;
  }

  @keyframes pulse {
    50% { opacity: 0.45; transform: scale(0.75); }
  }

  .kicker {
    margin-top: clamp(36px, 6vh, 62px);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.19em;
    text-transform: uppercase;
    color: rgba(243, 240, 235, 0.5);
  }

  h1 {
    margin-top: 18px;
    max-width: 11.5ch;
    font-size: clamp(54px, 7.7vw, 124px);
    font-weight: 520;
    letter-spacing: -0.065em;
    line-height: 0.87;
    text-wrap: balance;
  }

  h1 :global(em) {
    display: inline-block;
    font-style: normal;
    font-weight: 420;
    color: transparent;
    -webkit-text-stroke: 1.4px rgba(255, 150, 92, 0.95);
    text-shadow: 0 0 38px rgba(235, 75, 19, 0.18);
  }

  .intro {
    margin-top: 30px;
    max-width: 58ch;
    font-size: clamp(14px, 1.15vw, 17px);
    line-height: 1.75;
    color: rgba(243, 240, 235, 0.64);
    text-wrap: pretty;
  }

  .actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
    margin-top: 36px;
  }

  .btn--light {
    background: var(--paper-inv);
    color: var(--ink);
    min-height: 50px;
  }

  .btn--light:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 50px rgba(255, 104, 46, 0.18);
  }

  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding-block: 8px;
    border-bottom: 1px solid rgba(243, 240, 235, 0.3);
    font-size: 14px;
    font-weight: 600;
  }

  .text-link :global(svg) {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .text-link:hover :global(svg) {
    transform: translate(3px, -3px);
  }

  .spatial-labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    color: rgba(243, 240, 235, 0.55);
  }

  .label {
    position: absolute;
    display: flex;
    gap: 10px;
    align-items: center;
    padding: 7px 9px;
    border: 1px solid rgba(243, 240, 235, 0.14);
    background: rgba(9, 8, 7, 0.26);
    backdrop-filter: blur(12px);
    animation: drift 7s var(--ease-in-out) infinite;
  }

  .label::before {
    content: "";
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent-on-dark);
    box-shadow: 0 0 9px var(--accent-on-dark);
  }

  .label i {
    font-style: normal;
    opacity: 0.45;
  }

  .label--ai { left: 57%; top: 22%; }
  .label--motion { right: 8%; top: 44%; animation-delay: -2s; }
  .label--three { left: 60%; bottom: 22%; animation-delay: -4s; }

  @keyframes drift {
    50% { transform: translateY(-9px); }
  }

  .axis {
    position: absolute;
    right: 3%;
    bottom: 17%;
    padding-left: 28px;
    opacity: 0.42;
  }

  .axis::before {
    content: "";
    position: absolute;
    left: 0;
    top: 3px;
    width: 18px;
    border-top: 1px solid currentColor;
  }

  .hero-foot {
    position: absolute;
    left: var(--pad-x);
    right: var(--pad-x);
    bottom: 24px;
    z-index: 3;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: end;
    gap: 20px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    color: rgba(243, 240, 235, 0.4);
  }

  .hero-foot > :last-child { text-align: right; }

  .hero-foot a {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: rgba(243, 240, 235, 0.62);
  }

  .hero-foot a :global(svg) {
    animation: bounce 2.4s var(--ease-in-out) infinite;
  }

  @keyframes bounce {
    50% { transform: translateY(5px); }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      align-items: end;
      padding-top: 150px;
      padding-bottom: 126px;
    }
    .hero::after {
      background: linear-gradient(0deg, rgba(7, 6, 5, 0.9) 0%, rgba(7, 6, 5, 0.44) 58%, transparent 82%);
    }
    .hero-copy { max-width: 720px; }
    h1 { max-width: 10ch; }
    .spatial-labels { opacity: 0.7; }
    .label--ai { left: auto; right: 7%; top: 18%; }
    .label--motion { right: 7%; top: 31%; }
    .label--three { left: auto; right: 7%; bottom: 44%; }
    .axis { display: none; }
  }

  @media (max-width: 600px) {
    .hero { min-height: 820px; }
    .hero-grid {
      min-height: 820px;
      padding-inline: 20px;
      padding-top: 124px;
      padding-bottom: 104px;
    }
    .status { font-size: 9.5px; }
    .kicker { margin-top: 30px; }
    h1 {
      font-size: clamp(49px, 15.8vw, 74px);
      line-height: 0.91;
    }
    .intro {
      margin-top: 24px;
      max-width: 44ch;
      font-size: 13.5px;
      line-height: 1.65;
    }
    .actions { gap: 18px; margin-top: 28px; }
    .label--ai { top: 15%; }
    .label--motion { top: 24%; }
    .label--three { display: none; }
    .hero-foot {
      left: 20px;
      right: 20px;
      bottom: 18px;
      grid-template-columns: 1fr auto;
    }
    .hero-foot > :last-child { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-copy { opacity: 1; transform: none; animation: none; }
    .status i, .label, .hero-foot a :global(svg) { animation: none; }
  }
</style>

---
import { person } from "../data/profile";
import Icon from "./Icon.astro";
---

<section class="hero" id="top">
  <div class="hero-head">
    <div class="hero-title">
      <p class="kicker">{person.role.en}</p>
      <h1>
        <span class="ja" set:html={person.headline.ja} />
        <span class="en" set:html={person.headline.en} />
      </h1>
    </div>

    <div class="hero-aside">
      <p class="intro">
        <span class="ja">{person.intro.ja}</span>
        <span class="en">{person.intro.en}</span>
      </p>
      <div class="actions">
        <a href="#work">
          <span class="ja">制作を見る</span>
          <span class="en">Selected work</span>
          <Icon name="arrow-right" size={15} />
        </a>
        <a href="#contact">
          <span class="ja">相談する</span>
          <span class="en">Get in touch</span>
        </a>
      </div>
    </div>
  </div>

  <div class="visual" aria-label="Interactive geometric study">
    <div class="puzzle-pane puzzle-pane--one">
      <canvas data-hero-geometry aria-hidden="true"></canvas>
    </div>
    <div class="puzzle-pane puzzle-pane--two">
      <canvas data-hero-geometry aria-hidden="true"></canvas>
    </div>
    <div class="puzzle-pane puzzle-pane--three">
      <canvas data-hero-geometry aria-hidden="true"></canvas>
    </div>
  </div>

  <div class="hero-foot">
    <p>
      <i aria-hidden="true"></i>
      <span class="ja">2026年 秋以降のプロジェクト受付中</span>
      <span class="en">Available from Fall 2026</span>
    </p>
    <a href="#work">
      <span>SCROLL</span>
      <Icon name="chevron-down" size={16} />
    </a>
    <p>VANCOUVER / JAPAN</p>
  </div>
</section>

<script>
  import { initHeroGeometry } from "../scripts/hero-three";

  document.documentElement.classList.remove("intro-active", "intro-complete");
  const canvases = [...document.querySelectorAll<HTMLCanvasElement>("[data-hero-geometry]")];
  if (canvases.length === 3) initHeroGeometry(canvases);
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    padding: clamp(108px, 13vh, 142px) var(--pad-x) 28px;
    background: var(--paper);
    color: var(--ink);
  }

  .hero-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    align-items: end;
    gap: clamp(40px, 8vw, 140px);
    width: 100%;
    max-width: 1680px;
    margin-inline: auto;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.17em;
    color: var(--text-faint);
    text-transform: uppercase;
  }

  h1 {
    margin-top: 14px;
    max-width: 15ch;
    font-size: clamp(40px, 4.8vw, 72px);
    font-weight: 520;
    letter-spacing: -0.055em;
    line-height: 0.98;
    text-wrap: balance;
  }

  h1 :global(em) {
    font-style: normal;
    font-weight: 620;
    color: var(--ink);
  }

  .hero-aside {
    padding-bottom: 3px;
  }

  .intro {
    max-width: 40ch;
    font-size: clamp(13px, 0.95vw, 15px);
    line-height: 1.65;
    color: var(--text-muted);
    text-wrap: pretty;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 22px;
    margin-top: 20px;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--line-strong);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: border-color var(--dur-fast), opacity var(--dur-fast);
  }

  .actions a:last-child {
    border-bottom-color: transparent;
    color: var(--text-muted);
  }

  .actions a:hover {
    border-bottom-color: var(--ink);
    opacity: 0.62;
  }

  .visual {
    position: relative;
    width: 100%;
    max-width: 1680px;
    height: clamp(360px, 53vh, 640px);
    margin: clamp(32px, 5vh, 56px) auto 0;
    overflow: hidden;
    background: var(--paper);
  }

  .puzzle-pane {
    position: absolute;
    overflow: hidden;
    background: #171716;
    will-change: transform;
  }

  .puzzle-pane canvas {
    width: 100%;
    height: 100%;
  }

  .puzzle-pane--one {
    left: 0;
    width: 28%;
    height: 74%;
    animation: puzzle-one 13s var(--ease-in-out) infinite;
  }

  .puzzle-pane--two {
    left: 36%;
    width: 28%;
    height: 78%;
    animation: puzzle-two 13s var(--ease-in-out) infinite;
  }

  .puzzle-pane--three {
    right: 0;
    width: 28%;
    height: 72%;
    animation: puzzle-three 13s var(--ease-in-out) infinite;
  }

  @keyframes puzzle-one {
    0%, 100% { transform: translate3d(0, 0, 0); }
    28% { transform: translate3d(0, 30%, 0); }
    54% { transform: translate3d(14%, 14%, 0); }
    78% { transform: translate3d(0, 4%, 0); }
  }

  @keyframes puzzle-two {
    0%, 100% { transform: translate3d(0, 28%, 0); }
    28% { transform: translate3d(-8%, 0, 0); }
    54% { transform: translate3d(8%, 26%, 0); }
    78% { transform: translate3d(-12%, 5%, 0); }
  }

  @keyframes puzzle-three {
    0%, 100% { transform: translate3d(0, 4%, 0); }
    28% { transform: translate3d(0, 35%, 0); }
    54% { transform: translate3d(-8%, 0, 0); }
    78% { transform: translate3d(0, 24%, 0); }
  }

  .hero-foot {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: end;
    gap: 20px;
    width: 100%;
    max-width: 1680px;
    margin: 18px auto 0;
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.13em;
    color: var(--text-faint);
  }

  .hero-foot p {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-foot p:last-child {
    justify-content: flex-end;
  }

  .hero-foot i {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #82aa89;
  }

  .hero-foot a {
    display: flex;
    align-items: center;
    gap: 5px;
    color: var(--text-muted);
  }

  .hero-foot a :global(svg) {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .hero-foot a:hover :global(svg) {
    transform: translateY(3px);
  }

  @media (max-width: 820px) {
    .hero {
      min-height: 820px;
      padding-top: 112px;
      padding-inline: 20px;
    }

    .hero-head {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    h1 {
      font-size: clamp(38px, 11vw, 58px);
    }

    .intro {
      max-width: 47ch;
    }

    .visual {
      height: 430px;
      margin-top: 32px;
    }

    .puzzle-pane--one,
    .puzzle-pane--three {
      width: 30%;
    }

    .puzzle-pane--two {
      left: 36%;
      width: 28%;
    }

    .hero-foot {
      grid-template-columns: 1fr auto;
    }

    .hero-foot > :last-child {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .hero {
      min-height: 760px;
      padding-bottom: 20px;
    }

    .kicker {
      font-size: 8px;
    }

    h1 {
      max-width: 12ch;
      font-size: clamp(38px, 12.6vw, 54px);
    }

    .intro {
      font-size: 13px;
    }

    .visual {
      height: 330px;
    }

    .actions {
      margin-top: 16px;
    }

    .hero-foot {
      margin-top: 14px;
      font-size: 7px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .puzzle-pane {
      animation: none;
    }

    .puzzle-pane--two {
      transform: translate3d(0, 28%, 0);
    }

    .puzzle-pane--three {
      transform: translate3d(0, 4%, 0);
    }
  }
</style>

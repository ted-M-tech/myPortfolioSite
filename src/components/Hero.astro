---
import { person, socials } from "../data/profile";
import Icon from "./Icon.astro";

/**
 * コアを周回するノード。前田さんが実際に横断している領域を並べている。
 * 数と順序を変えると軌道上の配置が変わる（等間隔に割り振っている）。
 */
const orbit = [
  { label: "AI / ML", icon: "brain" },
  { label: "Data", icon: "database" },
  { label: "Cloud", icon: "cloud" },
  { label: "SCADA", icon: "factory" },
  { label: "Code", icon: "code" },
  { label: "Team", icon: "users" },
] as const;
---

<section class="hero on-dark" id="top">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>

  <div class="stage" id="hero-stage" aria-hidden="true">
    <!-- コア。ロゴのマークを内側に置き、周囲に光輪を回す -->
    <div class="core">
      <div class="core-glow"></div>
      <div class="core-disc">
        <img src="/brand/maepace-icon.svg" alt="" width="72" height="79" />
      </div>
      <div class="core-ring"></div>
    </div>

    {
      orbit.map((n) => (
        <div class="node" data-orbit-node>
          <span class="node-ic">
            <Icon name={n.icon} size={14} />
          </span>
          <b>{n.label}</b>
        </div>
      ))
    }
  </div>

  <div class="hero-copy wrap">
    <p class="eyebrow">
      <span class="ja">{person.role.ja} · {person.location.ja}</span>
      <span class="en">{person.role.en} · {person.location.en}</span>
    </p>

    <h1>
      <span class="ja" set:html={person.headline.ja} />
      <span class="en" set:html={person.headline.en} />
    </h1>

    <div class="actions">
      <a href="#work" class="btn btn--primary">
        <span class="ja">仕事を見る</span>
        <span class="en">See the work</span>
        <Icon name="arrow-right" size={17} />
      </a>
      <a href="#services" class="btn btn--ghost">
        <span class="ja">依頼を相談する</span>
        <span class="en">Work with me</span>
      </a>
    </div>

    <ul class="socials">
      {
        socials.map((s) => (
          <li>
            <a href={s.href} aria-label={s.label} target="_blank" rel="noopener noreferrer">
              <Icon name={s.icon} size={17} />
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <a class="cue" href="#work" aria-label="Scroll">
    <Icon name="chevron-down" size={22} />
  </a>
</section>

<script>
  import { initHeroOrbit } from "../scripts/hero-orbit";

  const canvas = document.getElementById("hero-canvas");
  const stage = document.getElementById("hero-stage");
  if (canvas instanceof HTMLCanvasElement && stage) {
    initHeroOrbit(
      canvas,
      stage,
      // ラベルは DOM 側に既にある。ここは個数を合わせるためだけに渡す
      Array.from(stage.querySelectorAll("[data-orbit-node]"), () => ({ label: "", icon: "" })),
    );
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: min(100svh, 960px);
    overflow: hidden;
    background: radial-gradient(120% 95% at 50% 38%, #1c1917 0%, #141210 46%, #0a0908 82%);
    color: var(--text-on-dark);
  }

  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .stage {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
  }

  /* ---------- コア ---------- */
  .core {
    position: absolute;
    left: 50%;
    top: 34%;
    translate: -50% -50%;
    width: min(34vh, 290px);
    height: min(34vh, 290px);
    z-index: 5;
    animation: float 10s var(--ease-in-out) infinite;
  }

  .core-glow {
    position: absolute;
    inset: -32%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 42%,
      rgba(255, 245, 235, 0.3),
      rgba(240, 131, 79, 0.12) 46%,
      transparent 70%
    );
    filter: blur(26px);
  }

  .core-disc {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background:
      radial-gradient(120% 120% at 34% 28%, #26221f 0%, #16130f 62%, #0d0b09 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 30px 90px rgba(0, 0, 0, 0.55);
  }

  /*
   * マークは単色。ブランド規定どおり傾けも歪めもしない。
   * <img> で読み込んだ SVG は currentColor を継承できず黒のまま出るので、
   * 暗い面に載せるここでは反転させて紙色にする。
   */
  .core-disc img {
    width: 34%;
    height: auto;
    filter: invert(1);
    opacity: 0.9;
  }

  .core-ring {
    position: absolute;
    inset: -3%;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  /* ---------- 周回ノード ---------- */
  .node {
    position: absolute;
    left: 0;
    top: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 13px 7px 8px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    white-space: nowrap;
    opacity: 0;
    will-change: transform, opacity;
    box-shadow: 0 8px 26px rgba(0, 0, 0, 0.35);
  }

  .node-ic {
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    flex: none;
  }

  .node b {
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  /* ---------- コピー ---------- */
  /*
   * 見出しの背後にごく薄い暗幕を敷く。軌道の線やノードが文字に重なっても
   * 読めなくならないようにするためで、四角い箱には見えないよう楕円でぼかす。
   */
  .hero-copy::before {
    content: "";
    position: absolute;
    inset: -14% -18%;
    z-index: -1;
    background: radial-gradient(60% 55% at 50% 52%, rgba(10, 9, 8, 0.86), transparent 72%);
    pointer-events: none;
  }

  .hero-copy {
    position: absolute;
    left: 50%;
    translate: -50% 0;
    bottom: 6vh;
    z-index: 20;
    text-align: center;
  }

  .eyebrow {
    color: var(--text-on-dark-muted);
  }

  h1 {
    margin: 16px auto 0;
    max-width: 17ch;
    font-size: clamp(32px, 5.4vw, 66px);
    font-weight: 600;
    letter-spacing: var(--tracking-display);
    line-height: 1.02;
    text-wrap: balance;
  }

  /* 日本語は文字単位で折り返せてしまうので、アクセントは塊で扱う */
  h1 :global(em) {
    display: inline-block;
    font-style: normal;
    color: var(--accent-on-dark);
  }

  .actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .socials {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 26px;
  }

  .socials a {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--line-on-dark);
    color: var(--text-on-dark-muted);
    transition:
      color var(--dur-fast),
      border-color var(--dur-fast),
      transform var(--dur-fast) var(--ease-out);
  }

  .socials a:hover {
    color: var(--text-on-dark);
    border-color: var(--paper-inv);
    transform: translateY(-2px);
  }

  .cue {
    position: absolute;
    left: 50%;
    bottom: 16px;
    translate: -50% 0;
    z-index: 20;
    color: rgba(243, 240, 235, 0.4);
    animation: bob 2.6s var(--ease-in-out) infinite;
  }

  @keyframes float {
    0%,
    100% {
      translate: -50% -50%;
    }
    50% {
      translate: -50% calc(-50% - 12px);
    }
  }

  @keyframes bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(7px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .core,
    .cue {
      animation: none;
    }
  }

  @media (max-width: 820px) {
    .hero-copy {
      bottom: 5vh;
    }
    .node b {
      font-size: 11.5px;
    }
  }
</style>

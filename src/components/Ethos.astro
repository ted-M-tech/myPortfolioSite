---
import { ethos, site, person } from "../data/profile";
---

<section class="ethos section section--dark" id="ethos">
  <div class="wrap">
    <header class="reveal">
      <div>
        <p class="eyebrow">Knowledge graph / 04</p>
        <h2 class="section-title">
          <span class="ja">{ethos.heading.ja}</span>
          <span class="en">{ethos.heading.en}</span>
        </h2>
      </div>
      <p class="section-lede">
        <span class="ja">
          知識、失敗、現場、技術、対話。<br />
          断片を自分の視点でつなぎ、一つの強い体験へ。
        </span>
        <span class="en">
          Knowledge, failure, field work, technology and dialogue.<br />
          Connect the fragments through a distinct point of view.
        </span>
      </p>
    </header>

    <div class="stage" id="ethos-stage">
      <canvas id="ethos-canvas" aria-hidden="true"></canvas>

      <div class="graph-meta graph-meta--top" aria-hidden="true">
        <span>LIVE KNOWLEDGE FIELD</span>
        <span><i></i> 180 DATA NODES</span>
      </div>

      {
        ethos.values.map((value, index) => (
          <div class="gnode gnode--hub" data-ethos-node data-index={index}>
            <i aria-hidden="true"></i>
            <span>
              <b>
                <span class="ja">{value.ja}</span>
                <span class="en">{value.en}</span>
              </b>
              <small>
                <span class="ja">{value.en}</span>
                <span class="en">{value.ja}</span>
              </small>
            </span>
          </div>
        ))
      }

      <div class="gnode gnode--core" id="ethos-center">
        <span class="node-index">CONCEPT / 01</span>
        <b>{site.brand}</b>
        <small>
          <span class="ja">自分だけの視点</span>
          <span class="en">DISTINCT POINT OF VIEW</span>
        </small>
      </div>

      <div class="gnode gnode--output" id="ethos-output">
        <span class="node-index">OUTPUT / NEXT</span>
        <span class="output-mark" aria-hidden="true"></span>
        <b>
          <span class="ja">まだ見ぬ<br />最高傑作</span>
          <span class="en">THE NEXT<br />MASTERPIECE</span>
        </b>
      </div>

      <div class="graph-meta graph-meta--bottom" aria-hidden="true">
        <span>OBSERVATION · EXPERIENCE · DATA · CRAFT · FAILURE · CURIOSITY</span>
        <span>GRAPH / ACTIVE</span>
      </div>
    </div>

    <div class="equation reveal" aria-label="Many inputs become one concept, then one masterpiece">
      <p><b>∞</b><span>INPUTS</span></p>
      <i>→</i>
      <p><b>1</b><span>CONCEPT</span></p>
      <i>→</i>
      <p><b>1</b><span>MASTERPIECE</span></p>
    </div>

    <p class="cap reveal">
      <span class="ja" set:html={ethos.caption.ja} />
      <span class="en" set:html={ethos.caption.en} />
    </p>
    <p class="sign reveal">— {person.name}</p>
  </div>
</section>

<script>
  import { initEthosConstellation } from "../scripts/ethos-constellation";

  const stage = document.getElementById("ethos-stage");
  const canvas = document.getElementById("ethos-canvas");
  const center = document.getElementById("ethos-center");
  const output = document.getElementById("ethos-output");
  if (stage && canvas instanceof HTMLCanvasElement && center && output) {
    const hubs = [...stage.querySelectorAll<HTMLElement>("[data-ethos-node]")];
    initEthosConstellation(stage, canvas, hubs, center, output);
  }
</script>

<style>
  .ethos {
    overflow: hidden;
    background:
      radial-gradient(90% 70% at 72% 48%, rgba(66, 45, 255, .12), transparent 66%),
      radial-gradient(70% 60% at 35% 55%, rgba(255, 91, 36, .08), transparent 64%),
      #0a0908;
  }

  header {
    display: grid;
    grid-template-columns: 1.04fr .96fr;
    align-items: end;
    gap: clamp(36px, 7vw, 104px);
  }

  header .section-lede { margin: 0; }

  .stage {
    position: relative;
    margin-top: clamp(54px, 8vw, 96px);
    height: min(76vh, 720px);
    min-height: 600px;
    overflow: hidden;
    border: 1px solid rgba(243, 240, 235, .11);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(rgba(243,240,235,.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(243,240,235,.025) 1px, transparent 1px),
      rgba(255, 255, 255, .012);
    background-size: 52px 52px;
    box-shadow: inset 0 0 120px rgba(0,0,0,.42);
  }

  #ethos-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .graph-meta {
    position: absolute;
    z-index: 6;
    left: 18px;
    right: 18px;
    display: flex;
    justify-content: space-between;
    gap: 18px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    color: rgba(243,240,235,.34);
    pointer-events: none;
  }

  .graph-meta--top { top: 16px; }
  .graph-meta--bottom { bottom: 15px; }

  .graph-meta i {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #72ff9a;
    box-shadow: 0 0 9px #72ff9a;
  }

  .gnode {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    will-change: transform, opacity;
  }

  .gnode--hub {
    display: flex;
    align-items: center;
    gap: 9px;
    width: max-content;
    max-width: 34vw;
    padding: 8px 11px 8px 8px;
    border: 1px solid rgba(243,240,235,.13);
    border-radius: 10px;
    background: rgba(12, 11, 10, .62);
    backdrop-filter: blur(12px);
    box-shadow: 0 10px 30px rgba(0,0,0,.24);
  }

  .gnode--hub > i {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: 50%;
    background: var(--node-color, var(--accent-on-dark));
    box-shadow: 0 0 13px var(--node-color, var(--accent-on-dark));
  }

  .gnode--hub:nth-of-type(3n + 1) { --node-color: #6178ff; }
  .gnode--hub:nth-of-type(3n + 2) { --node-color: #ff7540; }
  .gnode--hub:nth-of-type(3n) { --node-color: #d99cff; }

  .gnode--hub b, .gnode--hub small { display: block; }
  .gnode--hub b {
    font-size: 12px;
    font-weight: 560;
    line-height: 1.2;
  }
  .gnode--hub small {
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: .1em;
    color: rgba(243,240,235,.38);
  }

  .gnode--core {
    z-index: 8;
    display: grid;
    place-items: center;
    width: clamp(132px, 12vw, 176px);
    aspect-ratio: 1;
    padding: 20px;
    border: 1px solid rgba(255, 131, 75, .7);
    border-radius: 50%;
    text-align: center;
    background:
      radial-gradient(circle, rgba(255, 94, 37, .23), rgba(12,11,10,.94) 66%);
    box-shadow:
      0 0 0 16px rgba(255, 117, 64, .025),
      0 0 70px rgba(255, 75, 25, .22);
  }

  .gnode--core::before,
  .gnode--core::after {
    content: "";
    position: absolute;
    inset: -10px;
    border: 1px solid rgba(255,117,64,.16);
    border-radius: 50%;
  }
  .gnode--core::after { inset: -24px; opacity: .45; }

  .node-index {
    position: absolute;
    top: 17px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: .13em;
    color: rgba(243,240,235,.38);
  }

  .gnode--core b {
    margin-top: 8px;
    font-size: clamp(20px, 2.2vw, 31px);
    font-weight: 560;
    letter-spacing: -.045em;
  }
  .gnode--core small {
    position: absolute;
    bottom: 18px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: .09em;
    color: rgba(243,240,235,.46);
  }

  .gnode--output {
    z-index: 9;
    display: grid;
    place-items: center;
    width: clamp(150px, 15vw, 220px);
    aspect-ratio: 1;
    padding: 26px;
    border: 1px solid rgba(255, 190, 155, .78);
    border-radius: 6px;
    text-align: center;
    background:
      linear-gradient(135deg, rgba(255,117,64,.22), rgba(19,15,12,.96) 58%),
      #15110e;
    box-shadow:
      0 0 0 10px rgba(255,117,64,.025),
      0 0 0 22px rgba(255,117,64,.012),
      0 0 90px rgba(255,83,24,.28);
  }

  .gnode--output .node-index { top: 18px; color: rgba(255,206,180,.54); }
  .gnode--output b {
    position: relative;
    z-index: 2;
    font-size: clamp(18px, 2vw, 29px);
    font-weight: 540;
    line-height: 1.02;
    letter-spacing: -.035em;
  }

  .output-mark {
    position: absolute;
    inset: 16%;
    border: 1px solid rgba(255,255,255,.09);
    border-radius: 3px;
  }

  .equation {
    margin: 42px auto 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(20px, 4vw, 56px);
  }

  .equation p {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .equation b {
    font-size: clamp(28px, 4vw, 56px);
    font-weight: 520;
    line-height: 1;
  }
  .equation span {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    color: var(--text-on-dark-muted);
  }
  .equation > i {
    font-style: normal;
    color: var(--accent-on-dark);
  }

  .cap {
    margin: 34px auto 0;
    max-width: 34ch;
    text-align: center;
    font-size: clamp(20px, 2.7vw, 36px);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: var(--tracking-tight);
    color: rgba(243,240,235,.68);
    text-wrap: balance;
  }

  .cap :global(em) {
    font-style: normal;
    color: var(--accent-on-dark);
  }

  .sign {
    margin-top: 16px;
    text-align: center;
    font-size: 13px;
    letter-spacing: .08em;
    color: rgba(243,240,235,.32);
  }

  @media (max-width: 860px) {
    header { grid-template-columns: 1fr; gap: 22px; }
    header .section-lede { margin-top: 0; }
    .stage { min-height: 620px; }
  }

  @media (max-width: 620px) {
    .stage {
      width: calc(100% + 16px);
      margin-left: -8px;
      min-height: 640px;
    }
    .graph-meta--bottom span:first-child { display: none; }
    .gnode--hub {
      padding: 6px 8px 6px 6px;
      max-width: 42vw;
    }
    .gnode--hub b { font-size: 10px; }
    .gnode--hub small { display: none; }
    .gnode--core { width: 118px; }
    .gnode--output { width: 132px; padding: 18px; }
    .gnode--output b { font-size: 16px; }
    .equation { gap: 13px; }
    .equation span { font-size: 6.5px; }
  }
</style>

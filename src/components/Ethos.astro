---
import { ethos, person } from "../data/profile";
---

<section class="ethos section" id="ethos">
  <div class="wrap">
    <header class="reveal">
      <div>
        <p class="eyebrow">Knowledge graph / 04</p>
        <h2 class="section-title">
          <span class="ja">{ethos.heading.ja}</span>
          <span class="en">{ethos.heading.en}</span>
        </h2>
      </div>
      <p class="section-lede">
        <span class="ja">
          知識、失敗、現場、技術、対話。<br />
          断片を自分の視点でつなぎ、一つの強い体験へ。
        </span>
        <span class="en">
          Knowledge, failure, field work, technology and dialogue.<br />
          Connect the fragments through a distinct point of view.
        </span>
      </p>
    </header>

    <div class="stage" id="ethos-stage">
      <canvas id="ethos-canvas" aria-hidden="true"></canvas>

      {
        ethos.values.map((value, index) => (
          <div class="gnode gnode--hub" data-ethos-node data-index={index}>
            <i aria-hidden="true" />
            <b>
              <span class="ja">{value.ja}</span>
              <span class="en">{value.en}</span>
            </b>
          </div>
        ))
      }

      {/*
        ロゴマークそのものを「視点」のノードに置く。
        屋号の意味（前へ、自分の歩幅で）がこの図の中心と同じなので、
        ここが唯一、マークが装飾ではなく語り手になる場所になる。
        単色・無加工・周囲に余白（ブランド規定）を守ること。
      */}
      <div class="gnode gnode--core" id="ethos-center">
        <span class="mark" aria-hidden="true">
          <svg viewBox="0 0 960 1050" fill="currentColor">
            <g transform="translate(0,1050) scale(0.1,-0.1)">
              <path
                d="M4544 8019 c-231 -38 -391 -217 -804 -894 -131 -215 -297 -487 -370 -605 -46 -74 -109 -178 -140 -230 -32 -52 -95 -156 -140 -230 -109 -177 -277 -453 -372 -610 -42 -69 -113 -186 -158 -260 -46 -74 -118 -193 -160 -265 -43 -71 -149 -249 -237 -395 -88 -146 -207 -344 -265 -440 -109 -182 -137 -229 -223 -370 -28 -47 -95 -157 -147 -245 -53 -88 -147 -245 -210 -350 -201 -333 -329 -547 -383 -640 -28 -50 -68 -116 -88 -147 -122 -191 -118 -198 112 -198 191 0 172 -11 297 173 54 78 127 185 164 237 37 52 129 185 205 295 76 110 191 274 255 365 64 91 145 207 181 257 119 172 382 548 429 613 25 36 78 110 117 165 129 184 542 761 579 810 13 17 91 122 175 235 645 867 916 1080 1198 939 278 -139 450 -632 820 -2344 28 -132 58 -269 67 -305 28 -117 43 -183 79 -339 173 -750 366 -1066 679 -1112 374 -56 659 263 1113 1246 90 195 307 671 358 785 23 52 70 155 103 228 34 72 90 192 123 265 698 1509 1027 1573 1534 297 90 -227 144 -353 155 -364 17 -17 14 1703 -4 1723 -8 9 -69 147 -136 306 -276 658 -415 809 -700 764 -264 -42 -425 -278 -855 -1259 -42 -96 -98 -222 -125 -280 -27 -58 -75 -166 -108 -240 -63 -143 -267 -573 -300 -631 -10 -19 -52 -95 -93 -169 -294 -542 -503 -745 -763 -745 -355 0 -543 362 -921 1770 -22 84 -120 465 -185 720 -258 1019 -389 1328 -616 1443 -36 18 -149 44 -179 41 -5 -1 -33 -5 -61 -10z"
              />
            </g>
          </svg>
        </span>
        <span class="node-label">
          <span class="ja">自分の視点</span>
          <span class="en">A point of view</span>
        </span>
      </div>

      <div class="gnode gnode--output" id="ethos-output">
        <b>
          <span class="ja">まだ見ぬ<br />最高傑作</span>
          <span class="en">The next<br />masterpiece</span>
        </b>
      </div>
    </div>

    <p class="cap reveal">
      <span class="ja" set:html={ethos.caption.ja} />
      <span class="en" set:html={ethos.caption.en} />
    </p>
    <p class="sign reveal">— {person.name}</p>
  </div>
</section>

<script>
  import { initEthosConstellation } from "../scripts/ethos-constellation";

  const stage = document.getElementById("ethos-stage");
  const canvas = document.getElementById("ethos-canvas");
  const center = document.getElementById("ethos-center");
  const output = document.getElementById("ethos-output");
  if (stage && canvas instanceof HTMLCanvasElement && center && output) {
    const hubs = [...stage.querySelectorAll<HTMLElement>("[data-ethos-node]")];
    initEthosConstellation(stage, canvas, hubs, center, output);
  }
</script>

<style>
  /*
   * 反転面をやめた代わりに、一段沈めた面にしている。
   * 紙のままだと Work → Ethos → Skills → Process が明るい面の四連になり、
   * 節目が消えて一枚の長い面に見えてしまう。
   */
  .ethos {
    overflow: hidden;
    background:
      radial-gradient(72% 58% at 74% 46%, rgba(154, 168, 206, .18), transparent 68%),
      radial-gradient(64% 56% at 28% 58%, rgba(206, 172, 152, .14), transparent 66%),
      var(--surface-sunken);
  }

  header {
    display: grid;
    grid-template-columns: 1.04fr .96fr;
    align-items: end;
    gap: clamp(36px, 7vw, 104px);
  }

  header .section-lede { margin: 0; }

  .stage {
    position: relative;
    margin-top: clamp(54px, 8vw, 96px);
    height: min(72vh, 660px);
    min-height: 520px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(rgba(20, 17, 15, .022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(20, 17, 15, .022) 1px, transparent 1px),
      rgba(255, 255, 255, .5);
    background-size: 56px 56px;
  }

  #ethos-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .gnode {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    will-change: transform, opacity;
  }

  /* ---------- 6つの領域 ---------- */
  .gnode--hub {
    display: flex;
    align-items: center;
    gap: 8px;
    width: max-content;
    max-width: 34vw;
    padding: 6px 12px 6px 9px;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, .82);
    backdrop-filter: blur(8px);
  }

  .gnode--hub > i {
    width: 5px;
    height: 5px;
    flex: none;
    border-radius: 50%;
    background: var(--node-color, var(--text-faint));
  }

  .gnode--hub:nth-of-type(6n + 1) { --node-color: #7b8ab2; }
  .gnode--hub:nth-of-type(6n + 2) { --node-color: #ae8d9a; }
  .gnode--hub:nth-of-type(6n + 3) { --node-color: #7ca59c; }
  .gnode--hub:nth-of-type(6n + 4) { --node-color: #b59e6f; }
  .gnode--hub:nth-of-type(6n + 5) { --node-color: #9489b0; }
  .gnode--hub:nth-of-type(6n) { --node-color: #c18569; }

  .gnode--hub b {
    font-size: 12.5px;
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
    line-height: 1.3;
    white-space: nowrap;
  }

  /* ---------- 中心：ロゴマーク ---------- */
  .gnode--core {
    z-index: 8;
    display: grid;
    place-items: center;
    width: clamp(116px, 11vw, 152px);
    aspect-ratio: 1;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    background: var(--surface-raised);
  }

  /* 余白はマーク高さの 1/2 以上（docs/brand/maepace.md）。ここは 42% 幅で確保している */
  .mark {
    display: block;
    width: 42%;
    color: var(--ink);
  }

  .mark svg { width: 100%; height: auto; }

  .node-label {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-size: 11.5px;
    letter-spacing: .02em;
    color: var(--text-muted);
  }

  /* ---------- 出力：まだ踏んでいない一歩＝四角 ---------- */
  .gnode--output {
    z-index: 9;
    display: grid;
    place-items: center;
    width: clamp(132px, 13vw, 178px);
    aspect-ratio: 1;
    padding: 20px;
    border: 1px solid rgba(198, 72, 26, .3);
    border-radius: var(--radius);
    text-align: center;
    background: linear-gradient(160deg, rgba(222, 69, 19, .07), rgba(255, 255, 255, .92) 62%), #fff;
  }

  .gnode--output b {
    font-size: clamp(15px, 1.5vw, 21px);
    font-weight: 550;
    line-height: 1.24;
    letter-spacing: var(--tracking-tight);
  }

  /* ---------- 結び ---------- */
  .cap {
    margin: clamp(38px, 5vw, 56px) auto 0;
    max-width: 32ch;
    text-align: center;
    font-size: clamp(19px, 2.4vw, 31px);
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    text-wrap: balance;
  }

  .cap :global(em) {
    font-style: normal;
    color: var(--accent);
  }

  .sign {
    margin-top: 14px;
    text-align: center;
    font-size: 13px;
    letter-spacing: .06em;
    color: var(--text-faint);
  }

  @media (max-width: 860px) {
    header { grid-template-columns: 1fr; gap: 22px; }
    header .section-lede { margin-top: 0; }
    .stage { min-height: 560px; }
  }

  @media (max-width: 620px) {
    .stage {
      min-height: 580px;
      height: 74vh;
    }
    .gnode--hub {
      max-width: 44vw;
      padding: 5px 10px 5px 8px;
    }
    .gnode--hub b { font-size: 11px; }
    .gnode--core { width: 104px; }
    .gnode--output { width: 118px; padding: 14px; }
    .node-label { font-size: 10.5px; }
  }
</style>

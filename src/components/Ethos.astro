---
import { ethos, site, person } from "../data/profile";
---

<section class="section section--sunken section--textured" id="ethos">
  <div class="wrap">
    <header class="reveal">
      <p class="eyebrow">Ethos</p>
      <h2 class="section-title">
        <span class="ja">{ethos.heading.ja}</span>
        <span class="en">{ethos.heading.en}</span>
      </h2>
      <p class="section-lede">
        <span class="ja">
          屋号の {site.brand} は「前へ進む速度」と「自分のペース」の二重の意味を持たせています。
          速く動くことと、無理なく続けること。どちらも欠けると現場では続きません。
        </span>
        <span class="en">
          {site.brand} carries two meanings at once — forward momentum, and going at your own pace.
          Move fast, but at a pace you can sustain; drop either and it stops working in the field.
        </span>
      </p>
    </header>

    <!--
      スクロールで組み上がる星座。外周のノードが現れ、中心へスポークが伸び、
      環が閉じ、最後に光が中心へ流れ込む。
    -->
    <div class="stage" id="ethos-stage">
      <canvas id="ethos-canvas" aria-hidden="true"></canvas>

      {
        ethos.values.map((v) => (
          <div class="enode" data-ethos-node>
            <b>
              <span class="ja">{v.ja}</span>
              <span class="en">{v.en}</span>
            </b>
            <span class="sub">
              <span class="ja">{v.en}</span>
              <span class="en">{v.ja}</span>
            </span>
          </div>
        ))
      }

      <div class="enode enode--center" id="ethos-center">
        <b>
          <span class="ja">前へ</span>
          <span class="en">Forward</span>
        </b>
        <span class="sub">
          <span class="ja">MaePace</span>
          <span class="en">マエペース</span>
        </span>
      </div>
    </div>

    <p class="cap reveal">
      <span class="ja" set:html={ethos.caption.ja} />
      <span class="en" set:html={ethos.caption.en} />
    </p>

    <p class="sign reveal">— {person.name}</p>
  </div>
</section>

<script>
  import { initEthosConstellation } from "../scripts/ethos-constellation";

  const stage = document.getElementById("ethos-stage");
  const canvas = document.getElementById("ethos-canvas");
  const center = document.getElementById("ethos-center");
  if (stage && canvas instanceof HTMLCanvasElement && center) {
    const outer = [...stage.querySelectorAll<HTMLElement>("[data-ethos-node]")];
    initEthosConstellation(stage, canvas, outer, center);
  }
</script>

<style>
  .stage {
    position: relative;
    margin: 48px auto 0;
    max-width: 1000px;
    height: min(62vh, 520px);
    min-height: 420px;
  }

  #ethos-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .enode {
    position: absolute;
    left: 0;
    top: 0;
    /*
     * 内容幅で止める。absolute + flex だけだと shrink-to-fit が効かず
     * ステージ幅いっぱいまで伸び、狭い画面で横スクロールを生む。
     */
    width: max-content;
    max-width: 46vw;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    padding: 13px 22px;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow);
    white-space: nowrap;
    opacity: 0;
    will-change: transform, opacity;
  }

  .enode b {
    font-size: 16.5px;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  .enode .sub {
    font-size: 10px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-faint);
  }

  /* 中心だけ反転させて重心を作る */
  .enode--center {
    background: var(--surface-dark);
    color: var(--text-on-dark);
    padding: 20px 30px;
    border-color: transparent;
    box-shadow: 0 18px 50px rgba(20, 17, 15, 0.26);
    z-index: 5;
  }

  .enode--center b {
    font-size: 20px;
  }

  .enode--center .sub {
    color: var(--text-on-dark-muted);
  }

  .cap {
    margin-top: 40px;
    text-align: center;
    font-size: clamp(17px, 2.2vw, 25px);
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
    color: var(--text-muted);
    text-wrap: balance;
  }

  /* 原典の署名行。図の下に置いて、これが誰の言葉かを示す */
  .sign {
    margin-top: 14px;
    text-align: center;
    font-size: 15px;
    letter-spacing: 0.06em;
    color: var(--text-faint);
  }

  .cap :global(em) {
    font-style: normal;
    font-weight: 600;
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .enode {
      padding: 9px 15px;
    }
    .enode b {
      font-size: 13.5px;
    }
    .enode .sub {
      display: none;
    }
  }
</style>

---
import { play } from "../data/profile";
---

<section class="play section" id="play">
  <div class="wrap">
    <header class="play-head reveal">
      <p class="eyebrow">Beyond the screen / 05</p>
      <div>
        <h2 class="section-title">
          <span class="ja">前へ、<br />マイペースに。</span>
          <span class="en">Forward,<br />at my own pace.</span>
        </h2>
        <p class="section-lede">
          <span class="ja">画面を離れて、よく歩き、よく見る。余白が、次の発想を連れてきます。</span>
          <span class="en">Walking, looking and leaving room for the next idea.</span>
        </p>
      </div>
    </header>

    <ul class="grid stagger">
      {
        play.map((item, index) => (
          <li
            class:list={[
              "tile",
              `tile--${item.size}`,
              `tile--${item.id}`,
              item.image ? "tile--photo" : "tile--drawn",
              "reveal",
            ]}
            data-tilt
          >
            {item.image && (
              <img src={item.image} alt="" loading="lazy" decoding="async" width="1536" height="1024" />
            )}

            {/* 写真のない項目は線画で描く。それらしいストック写真を当てない。
                pace = トラックの周回と、その少し先に置いた次の一歩。
                ball = バスケ・野球・テニスを縫い目だけで描き分ける */}
            {item.motif === "pace" && (
              <svg class="motif" viewBox="0 0 200 150" fill="none" aria-hidden="true">
                <g stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke">
                  <rect x="16" y="42" width="168" height="74" rx="37" />
                  <rect x="30" y="56" width="140" height="46" rx="23" />
                  <rect x="44" y="70" width="112" height="18" rx="9" />
                </g>
              </svg>
            )}

            {item.motif === "ball" && (
              <svg class="motif" viewBox="0 0 240 88" fill="none" aria-hidden="true">
                <g stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke">
                  <circle cx="44" cy="44" r="34" />
                  <path d="M44 10v68M10 44h68" />
                  <path d="M44 10a38 38 0 0 0 0 68M44 10a38 38 0 0 1 0 68" />
                  <circle cx="120" cy="44" r="27" />
                  <path d="M100 22c12 14 12 30 0 44M140 22c-12 14-12 30 0 44" />
                  <circle cx="196" cy="44" r="21" />
                  <path d="M177 32c9 14 29 14 38 0M177 56c9-14 29-14 38 0" />
                </g>
              </svg>
            )}

            <span class="shade" aria-hidden="true"></span>
            <span class="tile-index">{String(index + 1).padStart(2, "0")}</span>
            <span class="caption">
              <b>
                <span class="ja">{item.name.ja}</span>
                <span class="en">{item.name.en}</span>
              </b>
              <span class="note">
                <span class="ja">{item.note.ja}</span>
                <span class="en">{item.note.en}</span>
              </span>
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .play {
    overflow: hidden;
    background: var(--paper);
  }

  .play-head {
    display: grid;
    grid-template-columns: minmax(180px, .6fr) minmax(0, 1.4fr);
    align-items: start;
    gap: clamp(36px, 8vw, 140px);
  }

  .play-head .section-title {
    margin-top: 0;
    max-width: 11ch;
  }

  .grid {
    margin-top: clamp(56px, 8vw, 104px);
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: clamp(145px, 14vw, 210px);
    gap: 14px;
  }

  .tile {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface-sunken);
    transform-style: preserve-3d;
  }

  .tile--lg {
    grid-column: span 3;
    grid-row: span 2;
  }

  .tile--md {
    grid-column: span 3;
  }

  .tile--wide {
    grid-column: span 4;
  }

  .tile--sm {
    grid-column: span 2;
  }

  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 900ms var(--ease-out);
  }

  .tile:hover img {
    transform: scale(1.035);
  }

  /* 横長タイルでは cover が縦を切るので、object-position の X は効かない。
     カメラを持った手は画角の下側にあるため、上へ寄せて枠外に落とす */
  .tile--travel img {
    object-position: center 38%;
  }

  /* ---------- 線画のタイル ---------- */
  .tile--drawn {
    background: var(--tile-tint);
  }

  .tile--running {
    --tile-tint: linear-gradient(160deg, #dfe9e6, #eef1ec 70%);
  }

  .tile--sports {
    --tile-tint: linear-gradient(160deg, #f2e8d6, #f6f1e6 72%);
  }

  .motif {
    position: absolute;
    z-index: 1;
    left: 50%;
    top: 42%;
    width: min(66%, 260px);
    height: auto;
    transform: translate(-50%, -50%);
    color: var(--ink);
    opacity: .34;
    transition: transform 900ms var(--ease-out);
  }

  .tile--drawn:hover .motif {
    transform: translate(-50%, -50%) scale(1.03);
  }

  .tile--sports .motif {
    width: min(78%, 220px);
  }

  .shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(12, 11, 10, .24), transparent 38%),
      linear-gradient(0deg, rgba(12, 11, 10, .72), transparent 56%);
    pointer-events: none;
  }

  /* 線画の面は明るいので、暗幕ではなく淡い紙色でキャプションを支える */
  .tile--drawn .shade {
    background: linear-gradient(0deg, rgba(247, 245, 242, .92), transparent 46%);
  }

  .tile-index {
    position: absolute;
    z-index: 2;
    top: 16px;
    left: 18px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .13em;
    color: rgba(255, 255, 255, .72);
  }

  .caption {
    position: absolute;
    z-index: 2;
    left: 20px;
    right: 20px;
    bottom: 18px;
    color: #fff;
    pointer-events: none;
  }

  .tile--drawn .tile-index {
    color: var(--text-faint);
  }

  .tile--drawn .caption {
    color: var(--text);
  }

  .tile--drawn .caption .note {
    color: var(--text-muted);
  }

  .caption b,
  .caption .note {
    display: block;
  }

  .caption b {
    font-size: clamp(18px, 1.5vw, 24px);
    font-weight: 600;
    letter-spacing: -.035em;
  }

  .caption .note {
    margin-top: 3px;
    max-width: 34ch;
    font-size: 11.5px;
    line-height: 1.5;
    color: rgba(255, 255, 255, .76);
  }

  @media (max-width: 820px) {
    .play-head {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .play-head .section-title {
      max-width: none;
    }

    .grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 180px;
    }

    .tile--lg {
      grid-column: span 2;
    }

    /* 2列では wide も1列にする。span 2 のままだと sm の隣が空いて
       行末に穴が残る（6列のときと同じで、穴は作らない） */
    .tile--wide,
    .tile--md,
    .tile--sm {
      grid-column: span 1;
    }
  }

  @media (max-width: 540px) {
    .grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }

    .tile--lg,
    .tile--wide,
    .tile--md,
    .tile--sm {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tile img {
      transition: none;
    }
  }
</style>

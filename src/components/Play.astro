---
import { play } from "../data/profile";
import Icon from "./Icon.astro";
---

<section class="section" id="play">
  <div class="wrap">
    <header class="reveal">
      <p class="eyebrow">Off the clock</p>
      <h2 class="section-title">
        <span class="ja">仕事のそと。</span>
        <span class="en">Beyond the screen.</span>
      </h2>
      <p class="section-lede">
        <span class="ja">
          手を動かしていない時間に見たものが、だいたい次の仕事に効いてきます。
        </span>
        <span class="en">
          What I see away from the keyboard usually turns up in the work later.
        </span>
      </p>
    </header>

    <!--
      6 列のベントー。lg は 3列×2行、md は 3列、sm は 2列を占める。
      写真は後から入れる。無い間もブランド面として成立するようにしてある。
    -->
    <ul class="grid stagger">
      {
        play.map((t) => (
          <li class:list={["tile", `tile--${t.size}`, `tile--${t.id}`, "reveal"]} data-tilt>
            {t.image ? (
              <img src={t.image} alt="" loading="lazy" decoding="async" />
            ) : (
              <span class="placeholder" aria-hidden="true">
                <Icon name={t.icon} size={26} />
              </span>
            )}
            <span class="scrim" aria-hidden="true" />
            <span class="cap">
              <b>
                <span class="ja">{t.name.ja}</span>
                <span class="en">{t.name.en}</span>
              </b>
              <span class="note">
                <span class="ja">{t.note.ja}</span>
                <span class="en">{t.note.en}</span>
              </span>
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .grid {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: clamp(130px, 13vw, 190px);
    gap: 16px;
  }

  .tile {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: #e9e3f1;
    border: 1px solid var(--line);
    transition: transform var(--dur) var(--ease-out);
  }

  .tile--lg {
    grid-column: span 3;
    grid-row: span 2;
  }
  .tile--md {
    grid-column: span 3;
  }
  .tile--wide {
    grid-column: span 4;
  }
  .tile--sm {
    grid-column: span 2;
  }

  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background:
      radial-gradient(80% 100% at 18% 16%, rgba(255,255,255,.72), transparent 58%),
      #e7e1f0;
    color: rgba(18, 17, 16, .5);
  }

  .tile--photo .placeholder { background-color: #dce8ee; }
  .tile--coffee .placeholder { background-color: #eadfd3; }
  .tile--reading .placeholder { background-color: #e8e3cc; }
  .tile--vancouver .placeholder { background-color: #dce8df; }

  .placeholder::after {
    content: "";
    position: absolute;
    width: 46%;
    aspect-ratio: 1;
    border: 1px solid currentColor;
    border-radius: 50%;
    opacity: .14;
  }

  .placeholder :global(svg) {
    position: relative;
    z-index: 2;
  }

  .scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(180deg, transparent 50%, rgba(255, 255, 255, .84));
    pointer-events: none;
  }

  .cap {
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 15px;
    z-index: 3;
    color: var(--text);
    pointer-events: none;
    text-shadow: none;
  }

  .cap b {
    display: block;
    font-size: 17px;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  .cap .note {
    font-size: 12.5px;
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .tile--lg {
      grid-column: span 2;
    }
    .tile--wide {
      grid-column: span 2;
    }
    .tile--md,
    .tile--sm {
      grid-column: span 1;
    }
  }
</style>

---
import { play } from "../data/profile";
---

<section class="play section" id="play">
  <div class="wrap">
    <header class="play-head reveal">
      <p class="eyebrow">Beyond the screen / 05</p>
      <div>
        <h2 class="section-title">
          <span class="ja">前へ、<br />マイペースに。</span>
          <span class="en">Forward,<br />at my own pace.</span>
        </h2>
        <p class="section-lede">
          <span class="ja">画面を離れて、よく歩き、よく見る。余白が、次の発想を連れてきます。</span>
          <span class="en">Walking, looking and leaving room for the next idea.</span>
        </p>
      </div>
    </header>

    <ul class="grid stagger">
      {
        play.map((item, index) => (
          <li
            class:list={[
              "tile",
              `tile--${item.size}`,
              `tile--${item.id}`,
              "reveal",
            ]}
            data-tilt
          >
            <img src={item.image} alt="" loading="lazy" decoding="async" width="1536" height="1024" />

            <span class="shade" aria-hidden="true"></span>
            <span class="tile-index">{String(index + 1).padStart(2, "0")}</span>
            <span class="caption">
              <b>
                <span class="ja">{item.name.ja}</span>
                <span class="en">{item.name.en}</span>
              </b>
              {item.note && (
                <span class="note">
                  <span class="ja">{item.note.ja}</span>
                  <span class="en">{item.note.en}</span>
                </span>
              )}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .play {
    overflow: hidden;
    background: var(--paper);
  }

  .play-head {
    display: grid;
    grid-template-columns: minmax(180px, .6fr) minmax(0, 1.4fr);
    align-items: start;
    gap: clamp(36px, 8vw, 140px);
  }

  .play-head .section-title {
    margin-top: 0;
    max-width: 11ch;
  }

  .grid {
    margin-top: clamp(56px, 8vw, 104px);
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: clamp(145px, 14vw, 210px);
    gap: 14px;
  }

  .tile {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface-sunken);
    transform-style: preserve-3d;
  }

  .tile--lg {
    grid-column: span 3;
    grid-row: span 2;
  }

  .tile--md {
    grid-column: span 3;
  }

  .tile--wide {
    grid-column: span 4;
  }

  .tile--sm {
    grid-column: span 2;
  }

  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 900ms var(--ease-out);
  }

  .tile:hover img {
    transform: scale(1.035);
  }

  /* 横長タイルでは cover が縦を切るので、object-position の X は効かない。
     カメラを持った手は画角の下側にあるため、上へ寄せて枠外に落とす */
  .tile--travel img {
    object-position: center 38%;
  }

  .shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(12, 11, 10, .24), transparent 38%),
      linear-gradient(0deg, rgba(12, 11, 10, .72), transparent 56%);
    pointer-events: none;
  }

  .tile-index {
    position: absolute;
    z-index: 2;
    top: 16px;
    left: 18px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .13em;
    color: rgba(255, 255, 255, .72);
  }

  .caption {
    position: absolute;
    z-index: 2;
    left: 20px;
    right: 20px;
    bottom: 18px;
    color: #fff;
    pointer-events: none;
  }

  .caption b,
  .caption .note {
    display: block;
  }

  .caption b {
    font-size: clamp(18px, 1.5vw, 24px);
    font-weight: 600;
    letter-spacing: -.035em;
  }

  .caption .note {
    margin-top: 3px;
    max-width: 34ch;
    font-size: 11.5px;
    line-height: 1.5;
    color: rgba(255, 255, 255, .76);
  }

  @media (max-width: 820px) {
    .play-head {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .play-head .section-title {
      max-width: none;
    }

    .grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 180px;
    }

    .tile--lg {
      grid-column: span 2;
    }

    /* 2列では wide も1列にする。span 2 のままだと sm の隣が空いて
       行末に穴が残る（6列のときと同じで、穴は作らない） */
    .tile--wide,
    .tile--md,
    .tile--sm {
      grid-column: span 1;
    }
  }

  /*
   * 狭い画面でも2列を保つ。1列に落とすと5枚で画面1.5枚ぶんになり、
   * 写真も横長のまま縦だけ縮んで中身が読めなくなる。
   * 先頭だけ全幅にして、残り4枚を2×2に収める。
   */
  @media (max-width: 540px) {
    .grid {
      grid-auto-rows: 150px;
      gap: 10px;
    }

    .tile--lg {
      grid-column: span 2;
      grid-row: span 1;
    }

    .tile--wide,
    .tile--md,
    .tile--sm {
      grid-column: span 1;
      grid-row: span 1;
    }

    .caption {
      left: 14px;
      right: 14px;
      bottom: 12px;
    }

    .caption b {
      font-size: 15px;
    }

    .caption .note {
      font-size: 10.5px;
    }

    .tile-index {
      top: 11px;
      left: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tile img {
      transition: none;
    }
  }
</style>

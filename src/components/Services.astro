---
import { services, servicesNote, person } from "../data/profile";
import Icon from "./Icon.astro";

/** 問い合わせは mailto に寄せる。予約基盤を挟まない分、壊れる箇所が減る */
const mailto = (title: string) =>
  `mailto:${person.email}?subject=${encodeURIComponent(`[${title}] のご相談`)}`;
---

<section class="section section--sunken" id="services">
  <div class="wrap">
    <header class="reveal">
      <p class="eyebrow">Work with me / 08</p>
      <h2 class="section-title">
        <span class="ja">「こんなの無理かも」から。</span>
        <span class="en">Start with the impossible idea.</span>
      </h2>
      <p class="section-lede">
        <span class="ja">
          企画が固まっていなくても大丈夫です。AI・技術相談、短期検証、フルスタック開発、
          継続的なプロダクト共同開発から、最短で価値を届ける形をご提案します。
        </span>
        <span class="en">
          Come with a rough thought, not a finished brief. From technical consultation
          to an AI prototype, full-stack build or product partnership, I’ll propose
          the fastest path to working value.
        </span>
      </p>
    </header>

    <ul class="grid stagger">
      {
        services.map((s) => (
          <li class:list={["plan", "reveal", s.featured && "plan--featured"]}>
            {s.featured && <span class="blob" aria-hidden="true" />}
            <p class:list={["badge", `badge--${s.tone}`]}>
              <span class="ja">{s.badge.ja}</span>
              <span class="en">{s.badge.en}</span>
            </p>

            <h3>
              <span class="ja">{s.title.ja}</span>
              <span class="en">{s.title.en}</span>
            </h3>
            <p class="sub">
              <span class="ja">{s.subtitle.ja}</span>
              <span class="en">{s.subtitle.en}</span>
            </p>

            <p class="price">
              <span class="ja">
                {s.price.ja}
                <small>{s.unit.ja}</small>
              </span>
              <span class="en">
                {s.price.en}
                <small>{s.unit.en}</small>
              </span>
            </p>

            <ul class="points">
              {s.points.map((p) => (
                <li>
                  <Icon name="check" size={17} />
                  <span class="ja">{p.ja}</span>
                  <span class="en">{p.en}</span>
                </li>
              ))}
            </ul>

            <a class="cta" href={mailto(s.title.ja)}>
              <span class="ja">{s.cta.ja}</span>
              <span class="en">{s.cta.en}</span>
            </a>
          </li>
        ))
      }
    </ul>

    <p class="note reveal">
      <span class="ja">{servicesNote.ja}</span>
      <span class="en">{servicesNote.en}</span>
    </p>
  </div>
</section>

<style>
  .grid {
    margin-top: 52px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    align-items: stretch;
  }

  .plan {
    display: flex;
    flex-direction: column;
    padding: 30px 26px;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    transition:
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }

  .plan:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }

  /* 推したいものだけ反転させる。色数を増やさずに序列をつける */
  .plan--featured {
    position: relative;
    background:
      radial-gradient(110% 80% at 85% 0%, rgba(255, 92, 35, .32), transparent 48%),
      radial-gradient(80% 70% at 0% 100%, rgba(70, 37, 255, .25), transparent 58%),
      var(--surface-dark);
    color: var(--text-on-dark);
    border-color: transparent;
    overflow: hidden;
  }

  /* 原典の cblob。反転面の角に光を置いて、平らな黒に見えないようにする */
  .blob {
    position: absolute;
    top: -60px;
    right: -40px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent), transparent 70%);
    opacity: 0.4;
    filter: blur(10px);
    pointer-events: none;
  }

  .badge {
    align-self: flex-start;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 5px 11px;
    border-radius: var(--radius-pill);
    background: var(--surface-sunken);
    color: var(--text-muted);
  }

  /* カードごとに色を変えて、4つが同じものの並びに見えないようにする */
  .badge--1 {
    background: var(--pastel-1);
    color: var(--on-pastel-1);
  }
  .badge--2 {
    background: var(--pastel-2);
    color: var(--on-pastel-2);
  }
  .badge--3 {
    background: var(--pastel-3);
    color: var(--on-pastel-3);
  }
  .badge--4 {
    background: var(--pastel-4);
    color: var(--on-pastel-4);
  }

  h3 {
    margin-top: 18px;
    font-size: 21px;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  .sub {
    margin-top: 4px;
    font-size: 13.5px;
    color: var(--text-muted);
  }

  .plan--featured .sub {
    color: var(--text-on-dark-muted);
  }

  .price {
    margin-top: 20px;
    font-size: 34px;
    font-weight: 600;
    letter-spacing: var(--tracking-display);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .price small {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--text-faint);
  }

  .plan--featured .price small {
    color: var(--text-on-dark-muted);
  }

  .points {
    display: flex;
    flex-direction: column;
    gap: 11px;
    margin: 20px 0 26px;
  }

  .points li {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--text-muted);
  }

  .plan--featured .points li {
    color: var(--text-on-dark-muted);
  }

  .points :global(svg) {
    flex: none;
    margin-top: 1px;
    color: var(--accent);
    opacity: 0.85;
  }

  .plan--featured .points :global(svg) {
    color: var(--accent-on-dark);
  }

  .cta {
    margin-top: auto;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    padding: 12px 16px;
    border-radius: var(--radius-pill);
    background: var(--ink);
    color: var(--paper);
    transition:
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur);
  }

  .plan--featured .cta {
    background: var(--paper-inv);
    color: var(--ink);
  }

  .cta:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow);
  }

  .note {
    margin-top: 30px;
    font-size: 13.5px;
    color: var(--text-faint);
    text-align: center;
    text-wrap: pretty;
  }

  @media (max-width: 1040px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 620px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import { toolchain } from "../data/profile";
import Icon from "./Icon.astro";
---

<section class="tools-universe" id="top" aria-labelledby="tool-hero-title">
  <div class="tools-copy" data-tools-copy>
    <p class="eyebrow">
      AI DRIVEN FULL STACK DEVELOPER
    </p>
    <h1 id="tool-hero-title">
      <span class="ja">好奇心を、<br />前へ進む力に。</span>
      <span class="en">Curiosity,<br />put in motion.</span>
    </h1>
    <p class="lede">
      <span class="ja">最先端を追い、試し、使いこなす。AI駆動の高速開発で、構想をプロダクトへ。</span>
      <span class="en">Tracking, testing and applying emerging technology — turning ideas into products through fast, AI-driven development.</span>
    </p>
    <div class="actions">
      <a href="#work">
        <span class="ja">制作を見る</span>
        <span class="en">Selected work</span>
        <Icon name="arrow-right" size={15} />
      </a>
      <a href="#contact">
        <span class="ja">相談する</span>
        <span class="en">Get in touch</span>
      </a>
    </div>
  </div>

  <div
    class="tool-stage"
    data-tool-stage
    aria-hidden="true"
  >
    {
      toolchain.map((tool, index) => (
        <div
          class="tool-token"
          data-tool-token
          data-index={index}
        >
          <img
            class:list={{ "is-app-icon": tool.appIcon }}
            src={tool.icon}
            alt={tool.name}
            width="72"
            height="72"
          />
        </div>
      ))
    }
  </div>

  {/* 名前の表示をやめたので、読み上げには名前だけを残す */}
  <p class="sr-only">
    <span class="ja">日常的に使うツール: {toolchain.map((t) => t.name).join("、")}</span>
    <span class="en">Tools used day to day: {toolchain.map((t) => t.name).join(", ")}</span>
  </p>

</section>

<script>
  import { initToolGravity } from "../scripts/tool-gravity";

  const stage = document.querySelector<HTMLElement>("[data-tool-stage]");
  if (stage) initToolGravity(stage);
</script>

<style>
  .tools-universe {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    border-top: 1px solid var(--line);
    background: #f1f3ef;
    color: var(--ink);
  }

  .tools-copy {
    position: absolute;
    z-index: 5;
    left: 50%;
    top: 43%;
    width: min(620px, calc(100% - 48px));
    text-align: center;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--text-faint);
  }

  h1 {
    margin-top: 18px;
    font-size: clamp(40px, 4.6vw, 62px);
    font-weight: 520;
    letter-spacing: -0.055em;
    line-height: 1.02;
    text-wrap: balance;
  }

  .lede {
    max-width: 44ch;
    margin: 24px auto 0;
    font-size: 13px;
    line-height: 1.7;
    color: var(--text-muted);
    text-wrap: pretty;
  }

  .actions {
    display: flex;
    justify-content: center;
    gap: 28px;
    margin-top: 24px;
    pointer-events: auto;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--line-strong);
    font-size: 11px;
    font-weight: 600;
  }

  .tool-stage {
    position: absolute;
    z-index: 4;
    inset: 0;
    overflow: hidden;
    touch-action: pan-y;
    pointer-events: none;
  }

  /*
   * ラベルもカードも持たない、マークだけのトークン。
   * 名前で補えない以上、載せるのは実在する公式マークだけ（profile.ts 参照）。
   * 正方形にしたので tool-gravity の円形当たり判定と実形状が一致する。
   */
  .tool-token {
    position: absolute;
    left: 0;
    top: 0;
    width: var(--tool-size, clamp(46px, 4vw, 62px));
    aspect-ratio: 1;
    opacity: 0;
    transform: translate3d(0, -140px, 0);
    transform-origin: center;
    will-change: transform;
    transition: opacity 420ms var(--ease-out);
    user-select: none;
  }

  /* 全部同寸だと整列した部品表に見える。3段の大小で疎密をつくる */
  .tool-token:nth-child(3n + 1) { --tool-size: clamp(54px, 4.9vw, 76px); }
  .tool-token:nth-child(4n + 3) { --tool-size: clamp(38px, 3.3vw, 50px); }

  /*
   * Cursor が配布しているアプリアイコンは角が立った正方形で、丸めるのは
   * OS 側の役目になっている（macOS が Dock で丸めているのと同じ）。
   * Claude の ClaudeIcon-Rounded.svg は最初から丸い形で配布されているので、
   * ここでの角丸は二重にはかからない。
   */
  .is-app-icon {
    border-radius: 22.4%;
  }

  .tool-token img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    /*
     * マークは加工しない。影だけで面から浮かせる。
     * ブランド色を影に混ぜると、淡い色のマークほど後光のような輪ができて
     * にじんで見えたので、影は無彩色に寄せて距離だけで浮かせている。
     */
    filter:
      drop-shadow(0 1px 1px rgba(20, 17, 15, .08))
      drop-shadow(0 10px 18px rgba(20, 17, 15, .1));
  }

  @media (max-width: 720px) {
    .tools-universe {
      min-height: 720px;
    }

    .tools-copy {
      width: min(460px, calc(100% - 40px));
    }

    h1 {
      font-size: clamp(38px, 11vw, 54px);
    }

    .lede {
      max-width: 34ch;
      font-size: 12.5px;
    }

    /* 小さいと床の上で団子になる。少し大きくして散らばらせる */
    .tool-token,
    .tool-token:nth-child(3n + 1),
    .tool-token:nth-child(4n + 3) {
      --tool-size: 50px;
    }

    .tool-token:nth-child(3n + 1) {
      --tool-size: 62px;
    }

  /* 動きを止める設定では、落として浮かせる代わりに静かに並べて見せる */
  @media (prefers-reduced-motion: reduce) {
    .tool-stage {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      align-content: space-between;
      justify-items: center;
      gap: 20px clamp(12px, 3vw, 32px);
      padding: 76px var(--pad-x) 58px;
    }

    .tool-token,
    .tool-token:nth-child(3n + 1),
    .tool-token:nth-child(4n + 3) {
      position: static;
      --tool-size: clamp(34px, 4vw, 52px);
      opacity: 1;
      transform: none !important;
    }
  }

  @media (max-width: 720px) and (prefers-reduced-motion: reduce) {
    .tool-stage {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      padding: 76px 16px 68px;
    }
  }
</style>

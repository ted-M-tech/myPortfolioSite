---
import { toolchain } from "../data/profile";
import Icon from "./Icon.astro";
---

<section class="tools-universe" id="top" aria-labelledby="tool-hero-title">
  <div class="tools-copy" data-tools-copy>
    <p class="eyebrow">
      AI DRIVEN FULL STACK DEVELOPER
    </p>
    <h1 id="tool-hero-title">
      <span class="ja">好奇心を、<br />前へ進む力に。</span>
      <span class="en">Curiosity,<br />put in motion.</span>
    </h1>
    <p class="lede">
      <span class="ja">最先端を追い、試し、使いこなす。AI駆動の高速開発で、構想をプロダクトへ。</span>
      <span class="en">Tracking, testing and applying emerging technology — turning ideas into products through fast, AI-driven development.</span>
    </p>
    <div class="actions">
      <a href="#work">
        <span class="ja">制作を見る</span>
        <span class="en">Selected work</span>
        <Icon name="arrow-right" size={15} />
      </a>
      <a href="#contact">
        <span class="ja">相談する</span>
        <span class="en">Get in touch</span>
      </a>
    </div>
  </div>

  <div
    class="tool-stage"
    data-tool-stage
    aria-hidden="true"
  >
    {
      toolchain.map((tool, index) => (
        <div
          class="tool-token"
          data-tool-token
          data-index={index}
          style={`--tool-color:${tool.color}`}
        >
          <span class:list={["tool-mark", { "tool-mark--official": tool.icon }]}>
            {
              tool.icon
                ? <img src={tool.icon} alt="" width="42" height="42" />
                : tool.genericIcon
                  ? <Icon name={tool.genericIcon} size={22} />
                  : null
            }
          </span>
          <span class="tool-name">{tool.name}</span>
        </div>
      ))
    }
  </div>

  <div class="hero-meta">
    <p><i aria-hidden="true"></i><span class="ja">2026年 秋以降のプロジェクト受付中</span><span class="en">Available from Fall 2026</span></p>
    <p class="tools-note" aria-hidden="true">
      <span>THINK</span>
      <span>DESIGN</span>
      <span>BUILD</span>
      <span>SHIP</span>
    </p>
    <p>VANCOUVER / JAPAN</p>
  </div>

  <p class="marks-note">
    Product names and marks belong to their respective owners. No affiliation or endorsement implied.
  </p>
</section>

<script>
  import { initToolGravity } from "../scripts/tool-gravity";

  const stage = document.querySelector<HTMLElement>("[data-tool-stage]");
  if (stage) initToolGravity(stage);
</script>

<style>
  .tools-universe {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    border-top: 1px solid var(--line);
    background: #f1f3ef;
    color: var(--ink);
  }

  .tools-copy {
    position: absolute;
    z-index: 5;
    left: 50%;
    top: 43%;
    width: min(620px, calc(100% - 48px));
    text-align: center;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--text-faint);
  }

  h1 {
    margin-top: 18px;
    font-size: clamp(40px, 4.6vw, 62px);
    font-weight: 520;
    letter-spacing: -0.055em;
    line-height: 1.02;
    text-wrap: balance;
  }

  .lede {
    max-width: 44ch;
    margin: 24px auto 0;
    font-size: 13px;
    line-height: 1.7;
    color: var(--text-muted);
    text-wrap: pretty;
  }

  .actions {
    display: flex;
    justify-content: center;
    gap: 28px;
    margin-top: 24px;
    pointer-events: auto;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--line-strong);
    font-size: 11px;
    font-weight: 600;
  }

  .tool-stage {
    position: absolute;
    z-index: 4;
    inset: 0;
    overflow: hidden;
    touch-action: pan-y;
    pointer-events: none;
  }

  .tool-token {
    position: absolute;
    left: 0;
    top: 0;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 9px;
    width: clamp(82px, 6.8vw, 108px);
    aspect-ratio: 1.42;
    padding: 9px 10px;
    border: 1px solid color-mix(in srgb, var(--tool-color) 15%, rgba(20, 17, 15, 0.1));
    border-radius: 15px;
    background:
      linear-gradient(
        145deg,
        rgba(255, 255, 255, 0.94),
        color-mix(in srgb, var(--tool-color) 11%, rgba(255, 255, 255, 0.88))
      );
    box-shadow:
      0 1px 1px rgba(20, 17, 15, 0.05),
      0 16px 38px rgba(20, 17, 15, 0.09);
    backdrop-filter: blur(10px);
    opacity: 0;
    transform: translate3d(0, -140px, 0);
    transform-origin: center;
    will-change: transform;
    transition: opacity 420ms var(--ease-out), box-shadow var(--dur) var(--ease-out);
    user-select: none;
  }

  .tool-mark {
    display: grid;
    place-items: center;
    width: clamp(29px, 2.35vw, 36px);
    aspect-ratio: 1;
    border-radius: 10px;
    background: var(--tool-color);
    color: #fff;
    font-size: clamp(11px, 1vw, 15px);
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .tool-mark--official {
    background: rgba(255, 255, 255, 0.96);
    box-shadow:
      inset 0 0 0 1px rgba(20, 17, 15, 0.07),
      0 2px 8px rgba(20, 17, 15, 0.05);
  }

  .tool-mark img {
    width: 72%;
    height: 72%;
    object-fit: contain;
  }

  .tool-name {
    overflow: hidden;
    font-size: clamp(9px, 0.78vw, 11px);
    font-weight: 620;
    letter-spacing: -0.02em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .hero-meta {
    position: absolute;
    z-index: 5;
    left: var(--pad-x);
    right: var(--pad-x);
    bottom: 18px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    color: var(--text-faint);
    pointer-events: none;
  }

  .hero-meta > p:first-child {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-meta > p:last-child {
    text-align: right;
  }

  .hero-meta i {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #72ab89;
  }

  .tools-note {
    display: flex;
    gap: clamp(28px, 5vw, 72px);
  }

  .marks-note {
    position: absolute;
    z-index: 5;
    right: var(--pad-x);
    bottom: 4px;
    font-family: var(--font-mono);
    font-size: 7px;
    letter-spacing: 0.06em;
    color: rgba(20, 17, 15, 0.32);
  }

  @media (max-width: 720px) {
    .tools-universe {
      min-height: 720px;
    }

    .tools-copy {
      width: min(460px, calc(100% - 40px));
    }

    h1 {
      font-size: clamp(38px, 11vw, 54px);
    }

    .lede {
      max-width: 34ch;
      font-size: 12.5px;
    }

    .tool-token {
      width: clamp(68px, 20vw, 86px);
      padding: 7px 8px;
      border-radius: 12px;
    }

    .tool-mark {
      width: 27px;
      border-radius: 7px;
    }

    .tool-name {
      font-size: 9px;
    }

    .hero-meta {
      grid-template-columns: 1fr 1fr;
    }

    .tools-note {
      display: none;
    }

    .marks-note {
      max-width: 58ch;
      text-align: right;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tool-stage {
      display: grid;
      grid-template-columns: repeat(8, minmax(62px, 96px));
      align-content: space-between;
      justify-content: space-between;
      gap: 12px;
      padding: 72px var(--pad-x) 54px;
    }

    .tool-token {
      position: static;
      width: 100%;
      opacity: 1;
      transform: none !important;
    }
  }

  @media (max-width: 720px) and (prefers-reduced-motion: reduce) {
    .tool-stage {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      padding: 72px 10px 64px;
    }

    .tool-token:nth-child(n + 11) {
      display: none;
    }

    .tool-name {
      display: none;
    }

    .tool-token {
      display: grid;
      grid-template-columns: 1fr;
      place-items: center;
      aspect-ratio: 1;
      padding: 7px;
    }
  }
</style>

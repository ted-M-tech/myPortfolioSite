---
import { timeline } from "../data/profile";
---

<section class="section section--dark" id="path">
  <div class="wrap">
    <header class="reveal">
      <p class="eyebrow">The path</p>
      <h2 class="section-title">
        <span class="ja">これまで。</span>
        <span class="en">Where I've been.</span>
      </h2>
    </header>

    <ol class="timeline">
      {
        timeline.map((t) => (
          <li class="job reveal">
            <div>
              <p class="org">{t.org}</p>
              <p class="role">
                <span class="ja">{t.role.ja}</span>
                <span class="en">{t.role.en}</span>
              </p>
            </div>
            <p class="period">{t.period}</p>
          </li>
        ))
      }
    </ol>

  </div>
</section>

<style>
  .timeline {
    margin-top: 52px;
    border-top: 1px solid var(--line-on-dark);
  }

  .job {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    padding-block: 22px;
    border-bottom: 1px solid var(--line-on-dark);
  }

  .org {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
  }

  .role {
    margin-top: 3px;
    font-size: 14px;
    color: var(--text-on-dark-muted);
    text-wrap: pretty;
  }

  .period {
    flex: none;
    font-size: 13.5px;
    color: var(--text-on-dark-muted);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 560px) {
    .job {
      flex-direction: column;
      gap: 6px;
    }
  }
</style>

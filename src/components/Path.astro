---
import { timeline } from "../data/profile";
---

<section class="section section--dark section--textured" id="path">
  <div class="wrap">
    <header class="reveal">
      <p class="eyebrow">The path</p>
      <h2 class="section-title">
        <span class="ja">これまで。</span>
        <span class="en">Where I've been.</span>
      </h2>
    </header>

    <ol class="timeline">
      {
        timeline.map((t) => (
          <li class="job reveal">
            <span class="logo" aria-hidden="true">{t.org.charAt(0)}</span>
            <div>
              <p class="org">{t.org}</p>
              <p class="role">
                <span class="ja">{t.role.ja}</span>
                <span class="en">{t.role.en}</span>
              </p>
            </div>
            <p class="period">{t.period}</p>
          </li>
        ))
      }
    </ol>

  </div>
</section>

<style>
  .timeline {
    margin-top: 52px;
    border-top: 1px solid var(--line-on-dark);
  }

  .job {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    align-items: center;
    gap: 24px;
    padding-block: 26px;
    border-bottom: 1px solid var(--line-on-dark);
  }

  /* 原典はここに企業ロゴを置く枠がある。頭文字で埋めて枠の役割を残す */
  .logo {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(243, 240, 235, 0.06);
    color: var(--text-on-dark-muted);
    font-size: 18px;
    font-weight: 600;
  }

  .org {
    font-size: 19px;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
  }

  .role {
    margin-top: 3px;
    font-size: 14px;
    color: var(--text-on-dark-muted);
    text-wrap: pretty;
  }

  .period {
    flex: none;
    font-size: 13.5px;
    color: var(--text-on-dark-muted);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 560px) {
    .job {
      grid-template-columns: 44px 1fr;
      gap: 6px 16px;
    }
    .period {
      grid-column: 2;
    }
  }
</style>

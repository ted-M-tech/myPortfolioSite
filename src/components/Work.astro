---
import { enablement, person, projects } from "../data/profile";
import EnablementPanel from "./EnablementPanel.astro";
import Icon from "./Icon.astro";
import ProjectPanel from "./ProjectPanel.astro";
import WorkStrip from "./WorkStrip.astro";

/* Hero を畳んだので、サイトの主張はこの節の見出しが引き受ける */
const headline = {
  ja: person.headline.ja.split(/<br\s*\/?\s*>/i),
  en: person.headline.en.split(/<br\s*\/?\s*>/i),
};

const enablementIcons = {
  notion: "/brand/tools/notion.svg",
  claude: "/brand/tools/claude.svg",
  git: "/brand/tools/git.svg",
} as const;
---

<section class="section" id="work">
  <div class="wrap">
    <header class="reveal head">
      <div>
        <p class="eyebrow">Selected work / 01</p>
        <h2 class="section-title">
          <span class="ja">{headline.ja.map((line) => <span set:html={line} />)}</span>
          <span class="en">{headline.en.map((line) => <span set:html={line} />)}</span>
        </h2>
      </div>
      <p class="section-lede">
        <span class="ja">{person.intro.ja}</span>
        <span class="en">{person.intro.en}</span>
      </p>
    </header>
  </div>

  <WorkStrip />

  <div class="wrap">
    <ul class="list">
      {
        projects.map((p, i) => (
          <li class="project reveal" data-tilt>
            <a href={p.href} target="_blank" rel="noopener noreferrer">
              <div class:list={["media", p.video && "media--video"]}>
                <span class="num">{String(i + 1).padStart(2, "0")}</span>
                <ProjectPanel index={i} />
              </div>

              <div class="body">
                <p class="role">
                  <span class="ja">{p.role.ja}</span>
                  <span class="en">{p.role.en}</span>
                </p>
                <h3>
                  <span class="ja">{p.title.ja}</span>
                  <span class="en">{p.title.en}</span>
                </h3>
                <p class="desc">
                  <span class="ja">{p.description.ja}</span>
                  <span class="en">{p.description.en}</span>
                </p>
                <ul class="tags">
                  {p.tech.map((t) => (
                    <li class="tag">{t}</li>
                  ))}
                </ul>
                <span class="more">
                  <span class="ja">詳しく見る</span>
                  <span class="en">View more</span>
                  <Icon name="arrow-up-right" size={16} />
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    <section class="enablement reveal" aria-labelledby="enablement-title">
      <header>
        <div>
          <p class="eyebrow">Enablement / alongside the build</p>
          <h3 id="enablement-title">
            <span class="ja">技術を、<br />組織の力に。</span>
            <span class="en">Make technology<br />part of the team.</span>
          </h3>
        </div>
        <p class="enablement-lede">
          <span class="ja">ツールを入れて終わりにしない。実務で使い続けられる運用まで設計します。</span>
          <span class="en">Not just setup. I design the operating system that keeps the change useful.</span>
        </p>
      </header>
      <ol class="enablement-cases">
        {
          enablement.map((item, index) => (
            <li class:list={["enablement-case", `enablement-case--${item.id}`]}>
              <div class="enablement-copy">
                <div class="enablement-topline">
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <span class:list={["enablement-mark", `enablement-mark--${item.id}`]} aria-hidden="true">
                    <img src={enablementIcons[item.id]} alt="" width="26" height="26" loading="lazy" />
                  </span>
                </div>
                <h4>
                  <span class="ja">{item.title.ja}</span>
                  <span class="en">{item.title.en}</span>
                </h4>
                <p>
                  <span class="ja">{item.description.ja}</span>
                  <span class="en">{item.description.en}</span>
                </p>
                <span class="case-caption">
                  <span class="ja">導入設計 · 定着支援 · 運用改善</span>
                  <span class="en">Design · Adoption · Operations</span>
                </span>
              </div>
              <div class="enablement-preview" aria-hidden="true">
                <EnablementPanel id={item.id} />
              </div>
            </li>
          ))
        }
      </ol>
    </section>
  </div>
</section>

<style>
  /* 見出しの各行は span。<br /> ではなくブロックで折る */
  .section-title :global(span > span) {
    display: block;
  }

  /* Hero と同じ扱い。色は変えず字幅だけで強調する */
  .section-title :global(em) {
    font-style: normal;
    font-weight: 700;
  }

  .head {
    display: grid;
    grid-template-columns: 1.1fr .9fr;
    gap: 48px;
    align-items: end;
  }

  .head .section-lede { margin: 0; }

  .list {
    margin-top: 76px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  .project a {
    display: grid;
    grid-template-columns: 1.26fr .74fr;
    min-height: 480px;
    background: color-mix(in srgb, var(--surface-raised) 76%, transparent);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      box-shadow var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }

  .project a:hover {
    box-shadow: var(--shadow-lg);
  }

  /* 傾きは tilt.ts が li 側に当てる。a 側で transform を触ると打ち消し合う */
  .project {
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* 交互に左右を入れ替えて単調さを避ける */
  .project:nth-child(even) a {
    grid-template-columns: .74fr 1.26fr;
  }
  .project:nth-child(even) .media {
    order: 2;
  }

  /*
   * 高さはテキスト側が決め、メディアはそれに追従する。
   * aspect-ratio でメディアに高さを決めさせると、幅が広い画面で
   * カードが縦に伸び、テキスト側に空白が残る。
   */
  .media {
    position: relative;
    min-height: 400px;
    background: var(--surface-dark);
    overflow: hidden;
  }

  .num {
    position: absolute;
    top: 16px;
    left: 18px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .12em;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--text-on-dark-muted);
  }

  .body {
    padding: clamp(28px, 3.4vw, 50px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .role {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-faint);
  }

  h3 {
    margin-top: 10px;
    font-size: clamp(27px, 3vw, 43px);
    font-weight: 550;
    letter-spacing: var(--tracking-display);
    line-height: 1.14;
    text-wrap: balance;
  }

  .desc {
    margin-top: 14px;
    /* 行長が伸びすぎると読みにくい。幅が広い画面でも文章は 58ch で止める */
    max-width: 58ch;
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.52;
    text-wrap: pretty;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 24px;
    font-size: 14.5px;
    font-weight: 600;
  }

  .more :global(svg) {
    transition: translate var(--dur-fast) var(--ease-out);
  }

  .project a:hover .more :global(svg) {
    translate: 3px -3px;
  }

  .enablement {
    margin-top: clamp(92px, 12vw, 160px);
    padding-block: clamp(48px, 6vw, 76px);
    border-block: 1px solid var(--line);
  }

  .enablement > header {
    display: grid;
    grid-template-columns: minmax(0, 1.22fr) minmax(260px, .78fr);
    align-items: end;
    gap: clamp(40px, 8vw, 132px);
  }

  .enablement > header h3 {
    margin-top: 14px;
    max-width: none;
    font-size: clamp(40px, 5.3vw, 74px);
    line-height: .98;
  }

  .enablement > header h3 > span {
    width: max-content;
    max-width: 100%;
  }

  .enablement-lede {
    max-width: 35ch;
    font-size: 14px;
    line-height: 1.75;
    color: var(--text-muted);
    text-wrap: pretty;
  }

  .enablement-cases {
    margin-top: clamp(56px, 8vw, 100px);
    border-top: 1px solid var(--line);
  }

  .enablement-case {
    display: grid;
    grid-template-columns: minmax(260px, .42fr) minmax(0, .58fr);
    min-height: 390px;
    border-bottom: 1px solid var(--line);
  }

  .enablement-case:nth-child(even) {
    grid-template-columns: minmax(0, .58fr) minmax(260px, .42fr);
  }

  .enablement-case:nth-child(even) .enablement-copy {
    order: 2;
    border-right: 0;
    border-left: 1px solid var(--line);
  }

  .enablement-copy {
    display: flex;
    flex-direction: column;
    padding: clamp(26px, 4vw, 54px);
    border-right: 1px solid var(--line);
  }

  .enablement-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    color: var(--text-faint);
  }

  .enablement-mark {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--surface-sunken) 80%, white);
    box-shadow: inset 0 0 0 1px var(--line);
  }

  .enablement-mark img {
    width: 24px;
    height: 24px;
    object-fit: contain;
  }

  .enablement h4 {
    max-width: 12ch;
    margin-top: auto;
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 560;
    line-height: 1.08;
    letter-spacing: -.045em;
  }

  .enablement-case p {
    margin-top: 16px;
    max-width: 34ch;
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-muted);
  }

  .case-caption {
    margin-top: 28px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .enablement-preview {
    position: relative;
    min-height: 390px;
    overflow: hidden;
    background: var(--surface-sunken);
  }

  .enablement-preview :global(.enablement-panel) {
    inset: clamp(20px, 3vw, 42px);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 860px) {
    .head { grid-template-columns: 1fr; gap: 22px; }
    .head .section-lede { margin-top: 0; }
    .project a,
    .project:nth-child(even) a {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .project:nth-child(even) .media {
      order: 0;
    }
    .enablement > header {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 24px;
    }

    .enablement-case,
    .enablement-case:nth-child(even) {
      grid-template-columns: 1fr;
    }

    .enablement-case:nth-child(even) .enablement-copy,
    .enablement-copy {
      order: 0;
      min-height: 300px;
      border: 0;
      border-bottom: 1px solid var(--line);
    }

    .enablement-preview {
      min-height: 330px;
    }
  }

  /*
   * 1列に落ちた狭い画面では、制作カード1枚がほぼ1画面を占める。
   * 画像枠が 400px 固定なのが効いているので、横幅なりの高さまで下げる。
   */
  @media (max-width: 720px) {
    .list {
      margin-top: 44px;
      gap: 18px;
    }

    .media {
      min-height: 0;
      aspect-ratio: 16 / 10;
    }

    /* 縦 9:16 の動画を 16:10 に入れると帯しか見えない。この案件だけ枠を立てる */
    .media--video {
      aspect-ratio: 4 / 3;
    }

    .enablement-copy,
    .enablement-case:nth-child(even) .enablement-copy {
      min-height: 0;
      padding-block: 26px;
    }

    .enablement-preview {
      min-height: 0;
      aspect-ratio: 4 / 3;
    }

    .enablement-cases {
      margin-top: 40px;
    }

    /*
     * この節の clamp は下限がデスクトップ寸法のままで、狭い画面でも
     * 見出し 40px・本文まわり 90px 余白が据え置かれていた。列幅が半分以下
     * なのに文字だけ原寸なので、2〜3行に折れて余白ばかりが伸びる。
     */
    .enablement {
      margin-top: 52px;
      padding-block: 30px;
    }

    .enablement > header {
      gap: 16px;
    }

    .enablement > header h3 {
      margin-top: 10px;
      font-size: 30px;
      line-height: 1.12;
    }

    .enablement > header p {
      margin-top: 12px;
      font-size: 13.5px;
      line-height: 1.7;
    }

    .enablement-copy {
      padding-inline: 20px;
    }

    .enablement-copy h4 {
      font-size: 22px;
      line-height: 1.2;
    }

    .enablement-copy p {
      margin-top: 12px;
      font-size: 13.5px;
      line-height: 1.6;
    }

    .case-caption {
      margin-top: 18px;
    }
  }
</style>

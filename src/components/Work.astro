---
import { enablement, projects } from "../data/profile";
import Icon from "./Icon.astro";
import ProjectPanel from "./ProjectPanel.astro";
import WorkStrip from "./WorkStrip.astro";
---

<section class="section" id="work">
  <div class="wrap">
    <header class="reveal head">
      <div>
        <p class="eyebrow">Selected work / 01</p>
        <h2 class="section-title">
          <span class="ja">構想を、<br />本番で動かす。</span>
          <span class="en">Ideas, running<br />in production.</span>
        </h2>
      </div>
      <p class="section-lede">
        <span class="ja">
          AI、モバイル、業務システム。<br />
          構想から本番運用まで、一気通貫で。
        </span>
        <span class="en">
          AI, mobile and business systems.<br />
          From idea to production, end to end.
        </span>
      </p>
    </header>
  </div>

  <WorkStrip />

  <div class="wrap">
    <ul class="list">
      {
        projects.map((p, i) => (
          <li class="project reveal" data-tilt>
            <a href={p.href} target="_blank" rel="noopener noreferrer">
              <div class="media">
                <span class="num">{String(i + 1).padStart(2, "0")}</span>
                <ProjectPanel index={i} />
              </div>

              <div class="body">
                <p class="role">
                  <span class="ja">{p.role.ja}</span>
                  <span class="en">{p.role.en}</span>
                </p>
                <h3>
                  <span class="ja">{p.title.ja}</span>
                  <span class="en">{p.title.en}</span>
                </h3>
                <p class="desc">
                  <span class="ja">{p.description.ja}</span>
                  <span class="en">{p.description.en}</span>
                </p>
                <ul class="tags">
                  {p.tech.map((t) => (
                    <li class="tag">{t}</li>
                  ))}
                </ul>
                <span class="more">
                  <span class="ja">詳しく見る</span>
                  <span class="en">View more</span>
                  <Icon name="arrow-up-right" size={16} />
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    <section class="enablement reveal" aria-labelledby="enablement-title">
      <header>
        <p class="eyebrow">Enablement / alongside the build</p>
        <h3 id="enablement-title">
          <span class="ja">技術を、組織の力に。</span>
          <span class="en">Make the technology stick.</span>
        </h3>
      </header>
      <ul>
        {
          enablement.map((item) => (
            <li>
              <span class:list={["enablement-mark", `enablement-mark--${item.id}`]} aria-hidden="true">
                {item.mark}
              </span>
              <div>
                <h4>
                  <span class="ja">{item.title.ja}</span>
                  <span class="en">{item.title.en}</span>
                </h4>
                <p>
                  <span class="ja">{item.description.ja}</span>
                  <span class="en">{item.description.en}</span>
                </p>
              </div>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</section>

<style>
  .head {
    display: grid;
    grid-template-columns: 1.1fr .9fr;
    gap: 48px;
    align-items: end;
  }

  .head .section-lede { margin: 0; }

  .list {
    margin-top: 76px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  .project a {
    display: grid;
    grid-template-columns: 1.26fr .74fr;
    min-height: 480px;
    background: color-mix(in srgb, var(--surface-raised) 76%, transparent);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      box-shadow var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }

  .project a:hover {
    box-shadow: var(--shadow-lg);
  }

  /* 傾きは tilt.ts が li 側に当てる。a 側で transform を触ると打ち消し合う */
  .project {
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* 交互に左右を入れ替えて単調さを避ける */
  .project:nth-child(even) a {
    grid-template-columns: .74fr 1.26fr;
  }
  .project:nth-child(even) .media {
    order: 2;
  }

  /*
   * 高さはテキスト側が決め、メディアはそれに追従する。
   * aspect-ratio でメディアに高さを決めさせると、幅が広い画面で
   * カードが縦に伸び、テキスト側に空白が残る。
   */
  .media {
    position: relative;
    min-height: 400px;
    background: var(--surface-dark);
    overflow: hidden;
  }

  .num {
    position: absolute;
    top: 16px;
    left: 18px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .12em;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--text-on-dark-muted);
  }

  .body {
    padding: clamp(28px, 3.4vw, 50px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .role {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-faint);
  }

  h3 {
    margin-top: 10px;
    font-size: clamp(27px, 3vw, 43px);
    font-weight: 550;
    letter-spacing: var(--tracking-display);
    line-height: 1.14;
    text-wrap: balance;
  }

  .desc {
    margin-top: 14px;
    /* 行長が伸びすぎると読みにくい。幅が広い画面でも文章は 58ch で止める */
    max-width: 58ch;
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.52;
    text-wrap: pretty;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 24px;
    font-size: 14.5px;
    font-weight: 600;
  }

  .more :global(svg) {
    transition: translate var(--dur-fast) var(--ease-out);
  }

  .project a:hover .more :global(svg) {
    translate: 3px -3px;
  }

  .enablement {
    margin-top: clamp(92px, 12vw, 160px);
    padding-block: clamp(48px, 6vw, 76px);
    border-block: 1px solid var(--line);
  }

  .enablement > header {
    display: grid;
    grid-template-columns: .75fr 1.25fr;
    align-items: end;
    gap: 40px;
  }

  .enablement > header h3 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(34px, 5.2vw, 72px);
    line-height: .98;
  }

  .enablement > ul {
    margin-top: clamp(44px, 6vw, 72px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .enablement > ul > li {
    min-height: 250px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 52px;
    background: var(--surface-raised);
  }

  .enablement-mark {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 13px;
    background: #171717;
    color: #fff;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: -.02em;
  }

  .enablement-mark--claude { background: #d97757; }
  .enablement-mark--git { background: #7569d8; }

  .enablement h4 {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  .enablement li p {
    margin-top: 8px;
    max-width: 30ch;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--text-muted);
  }

  @media (max-width: 860px) {
    .head { grid-template-columns: 1fr; gap: 22px; }
    .head .section-lede { margin-top: 0; }
    .project a,
    .project:nth-child(even) a {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .project:nth-child(even) .media {
      order: 0;
    }
    .enablement > header {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 16px;
    }
    .enablement > ul {
      grid-template-columns: 1fr;
    }
    .enablement > ul > li {
      min-height: 0;
      gap: 42px;
    }
  }
</style>

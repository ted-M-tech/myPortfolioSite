---
import { projects } from "../data/profile";
import Icon from "./Icon.astro";
import ProjectPanel from "./ProjectPanel.astro";
import WorkStrip from "./WorkStrip.astro";
---

<section class="section" id="work">
  <div class="wrap">
    <header class="reveal head">
      <div>
        <p class="eyebrow">Selected work / 01</p>
        <h2 class="section-title">
          <span class="ja">実装までが、<br />デザイン。</span>
          <span class="en">Design ends<br />when it works.</span>
        </h2>
      </div>
      <p class="section-lede">
        <span class="ja">
          AI、モバイル、リアルタイムデータ、制御システム。
          異なる領域を、触って理解できる一つの体験にまとめてきました。
        </span>
        <span class="en">
          AI, mobile, real-time data and control systems — different disciplines
          shaped into experiences people can understand by using.
        </span>
      </p>
    </header>
  </div>

  <WorkStrip />

  <div class="wrap">
    <ul class="list">
      {
        projects.map((p, i) => (
          <li class="project reveal" data-tilt>
            <a href={p.href} target="_blank" rel="noopener noreferrer">
              <div class="media">
                <span class="num">{String(i + 1).padStart(2, "0")}</span>
                <ProjectPanel index={i} />
              </div>

              <div class="body">
                <p class="role">
                  <span class="ja">{p.role.ja}</span>
                  <span class="en">{p.role.en}</span>
                </p>
                <h3>
                  <span class="ja">{p.title.ja}</span>
                  <span class="en">{p.title.en}</span>
                </h3>
                <p class="desc">
                  <span class="ja">{p.description.ja}</span>
                  <span class="en">{p.description.en}</span>
                </p>
                <ul class="tags">
                  {p.tech.map((t) => (
                    <li class="tag">{t}</li>
                  ))}
                </ul>
                <span class="more">
                  <span class="ja">詳しく見る</span>
                  <span class="en">View more</span>
                  <Icon name="arrow-up-right" size={16} />
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .head {
    display: grid;
    grid-template-columns: 1.1fr .9fr;
    gap: 48px;
    align-items: end;
  }

  .head .section-lede { margin: 0; }

  .list {
    margin-top: 76px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  .project a {
    display: grid;
    grid-template-columns: 1.26fr .74fr;
    min-height: 520px;
    background: color-mix(in srgb, var(--surface-raised) 76%, transparent);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      box-shadow var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }

  .project a:hover {
    box-shadow: var(--shadow-lg);
  }

  /* 傾きは tilt.ts が li 側に当てる。a 側で transform を触ると打ち消し合う */
  .project {
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* 交互に左右を入れ替えて単調さを避ける */
  .project:nth-child(even) a {
    grid-template-columns: .74fr 1.26fr;
  }
  .project:nth-child(even) .media {
    order: 2;
  }

  /*
   * 高さはテキスト側が決め、メディアはそれに追従する。
   * aspect-ratio でメディアに高さを決めさせると、幅が広い画面で
   * カードが縦に伸び、テキスト側に空白が残る。
   */
  .media {
    position: relative;
    min-height: 400px;
    background: var(--surface-dark);
    overflow: hidden;
  }

  .num {
    position: absolute;
    top: 16px;
    left: 18px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .12em;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--text-on-dark-muted);
  }

  .body {
    padding: clamp(28px, 3.8vw, 58px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .role {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-faint);
  }

  h3 {
    margin-top: 10px;
    font-size: clamp(28px, 3.4vw, 48px);
    font-weight: 550;
    letter-spacing: var(--tracking-display);
    line-height: 1.14;
    text-wrap: balance;
  }

  .desc {
    margin-top: 14px;
    /* 行長が伸びすぎると読みにくい。幅が広い画面でも文章は 58ch で止める */
    max-width: 58ch;
    color: var(--text-muted);
    font-size: 16px;
    line-height: 1.55;
    text-wrap: pretty;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 24px;
    font-size: 14.5px;
    font-weight: 600;
  }

  .more :global(svg) {
    transition: translate var(--dur-fast) var(--ease-out);
  }

  .project a:hover .more :global(svg) {
    translate: 3px -3px;
  }

  @media (max-width: 860px) {
    .head { grid-template-columns: 1fr; gap: 22px; }
    .head .section-lede { margin-top: 0; }
    .project a,
    .project:nth-child(even) a {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .project:nth-child(even) .media {
      order: 0;
    }
  }
</style>

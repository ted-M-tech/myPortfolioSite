---
/**
 * 案件カードの図版。
 *
 * 写真は使わない。実際の成果物（工場の制御画面や社内 SaaS）は出せないものが多く、
 * 汎用のストック画像を置くと見た目が嘘になる。
 *
 * 代わりに計器の画面を思わせる面を描く。格子の上に信号の履歴が重なり、
 * 手前に現在の波形、その先に「まだ来ていない次の値」の四角が浮く。
 * ロゴの歩幅モチーフと、前田さんが実際に扱っている領域の両方に掛けている。
 *
 * 枠いっぱいに描くことが要件。中央に小さく置くと、余白ばかりの箱になる。
 */
interface Props {
  /** 0 始まり。波形・格子・密度がこれで変わる */
  index: number;
  /**
   * 波形を引くアニメーションを使うか。
   * 横流しの帯のように、祖先に .reveal を持たない場所では false にして
   * 最初から引かれた状態を出す（そうしないと線が出ないままになる）。
   */
  animate?: boolean;
}

const { index, animate = true } = Astro.props;

/** 案件ごとの波形。viewBox 0 0 400 260 の座標系で、左端から右端まで貫く */
const traces = [
  {
    main: "M-10,196 L44,96 L86,168 L134,52 L182,142 L232,128 L268,132 L410,132",
    ghosts: [
      "M-10,208 L40,120 L84,180 L130,74 L180,158 L230,146 L268,150 L410,150",
      "M-10,182 L48,74 L90,156 L138,34 L186,126 L234,112 L268,116 L410,116",
    ],
    cols: 13,
    rows: 8,
  },
  {
    main: "M-10,176 L38,120 L78,192 L122,62 L166,158 L214,104 L262,118 L410,118",
    ghosts: [
      "M-10,190 L36,140 L76,204 L120,84 L164,174 L212,124 L262,136 L410,136",
      "M-10,160 L42,100 L82,178 L126,42 L170,142 L216,86 L262,100 L410,100",
    ],
    cols: 11,
    rows: 7,
  },
  {
    main: "M-10,206 L52,88 L92,158 L128,102 L172,172 L226,120 L268,124 L410,124",
    ghosts: [
      "M-10,220 L50,110 L90,172 L126,120 L170,186 L224,138 L268,142 L410,142",
      "M-10,192 L56,68 L96,144 L132,84 L176,158 L228,102 L268,106 L410,106",
    ],
    cols: 15,
    rows: 9,
  },
  {
    main: "M-10,186 L46,110 L84,150 L130,66 L178,132 L228,150 L268,138 L410,138",
    ghosts: [
      "M-10,200 L44,132 L82,164 L128,88 L176,148 L226,166 L268,156 L410,156",
      "M-10,172 L50,90 L88,138 L134,48 L182,118 L230,134 L268,122 L410,122",
    ],
    cols: 12,
    rows: 7,
  },
  {
    main: "M-10,166 L40,104 L84,182 L126,88 L170,146 L220,96 L266,110 L410,110",
    ghosts: [
      "M-10,180 L38,124 L82,196 L124,110 L168,162 L218,116 L266,128 L410,128",
      "M-10,152 L44,84 L88,168 L130,68 L174,130 L222,78 L266,92 L410,92",
    ],
    cols: 14,
    rows: 8,
  },
  {
    main: "M-10,214 L48,124 L90,170 L132,78 L180,160 L230,134 L268,146 L410,146",
    ghosts: [
      "M-10,228 L46,146 L88,184 L130,100 L178,176 L228,152 L268,162 L410,162",
      "M-10,200 L52,104 L94,156 L136,58 L184,144 L232,116 L268,130 L410,130",
    ],
    cols: 10,
    rows: 9,
  },
];

const t = traces[index % traces.length]!;
/** 尾の終点の少し先。ロゴ規定どおり、近づけすぎず離しすぎない */
const squareY = [132, 118, 124, 138, 110, 146][index % 6]!;
const uid = `pp${index}`;
---

<div class:list={["panel", !animate && "panel--static"]} aria-hidden="true">
  <svg viewBox="0 0 400 260" preserveAspectRatio="xMidYMid slice" role="presentation">
    <defs>
      <!-- 手前の波形だけ、進むほど濃くする -->
      <linearGradient id={`${uid}-stroke`} x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="rgba(243,240,235,0.35)"></stop>
        <stop offset="62%" stop-color="rgba(243,240,235,0.95)"></stop>
        <stop offset="100%" stop-color="rgba(243,240,235,0.95)"></stop>
      </linearGradient>
      <!-- 下端に向けて沈ませ、テキスト側との境目を柔らかくする -->
      <linearGradient id={`${uid}-fade`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="rgba(255,255,255,0.16)"></stop>
        <stop offset="100%" stop-color="rgba(255,255,255,0)"></stop>
      </linearGradient>
    </defs>

    <!-- 格子。計器の目盛りに見立てて枠いっぱいに敷く -->
    <g class="grid">
      {
        Array.from({ length: t.cols + 1 }, (_, i) => (
          <line x1={(400 / t.cols) * i} y1="0" x2={(400 / t.cols) * i} y2="260" stroke="rgba(243,240,235,0.08)" stroke-width="0.6" />
        ))
      }
      {
        Array.from({ length: t.rows + 1 }, (_, i) => (
          <line x1="0" y1={(260 / t.rows) * i} x2="400" y2={(260 / t.rows) * i} stroke="rgba(243,240,235,0.08)" stroke-width="0.6" />
        ))
      }
    </g>

    <!-- 上端の淡い光。面が真っ黒に沈まないようにする -->
    <rect x="0" y="0" width="400" height="260" fill={`url(#${uid}-fade)`}></rect>

    <!-- 過去の履歴。奥に薄く重ねる -->
    <g class="ghosts">
      {t.ghosts.map((d) => <path d={d} fill="none" stroke="rgba(243,240,235,0.14)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />)}
    </g>

    <!-- 現在の波形 -->
    <path class="trace" d={t.main} fill="none" stroke={`url(#${uid}-stroke)`} stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" />

    <!-- まだ来ていない次の値 -->
    <rect class="next" x="300" y={squareY - 9} width="18" height="18" rx="1"></rect>
  </svg>
</div>

<style>
  .panel {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background:
      radial-gradient(120% 90% at 78% 30%, #2a2521 0%, #1a1714 44%, #0e0c0a 100%);
  }

  svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* 描画属性は SVG 側に直接書いてある。ここは動きの分だけ */
  .trace {
    /* 実測より長く取っておけば、どの波形でも全体が隠れる */
    stroke-dasharray: 900;
    stroke-dashoffset: 900;
  }

  .next {
    fill: var(--accent-on-dark);
    opacity: 0;
  }

  /* カードが画面に入ったら波形が引かれ、最後に次の値が現れる */
  @media (prefers-reduced-motion: no-preference) {
    :global(.reveal.is-in) .trace {
      animation: draw 1.7s var(--ease-out) forwards;
    }
    :global(.reveal.is-in) .next {
      animation: appear 0.5s var(--ease-out) 1.4s forwards;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trace {
      stroke-dashoffset: 0;
    }
    .next {
      opacity: 1;
    }
  }

  /* 引くアニメーションを使わない置き方 */
  .panel--static .trace {
    stroke-dashoffset: 0;
  }
  .panel--static .next {
    opacity: 1;
  }

  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes appear {
    from {
      opacity: 0;
      transform: translateX(-8px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>

---
import { projects } from "../data/profile";

interface Props {
  index: number;
  animate?: boolean;
}

const { index, animate = true } = Astro.props;
const project = projects[index];
---

<div class:list={["panel", animate && "panel--animate"]}>
  <picture>
    <img
      src={project.image}
      alt={project.imageAlt.ja}
      loading="lazy"
      decoding="async"
      width="1536"
      height="1024"
    />
  </picture>
  <span class="veil" aria-hidden="true"></span>
  <span class="label">
    <span class="ja">画面イメージ</span>
    <span class="en">Concept visual</span>
  </span>
</div>

<style>
  .panel {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: #e9e5df;
  }

  picture,
  img {
    width: 100%;
    height: 100%;
  }

  picture {
    display: block;
  }

  img {
    display: block;
    object-fit: cover;
    transition: transform 900ms var(--ease-out);
  }

  .panel--animate img {
    transform: scale(1.01);
  }

  :global(.project a:hover) .panel--animate img {
    transform: scale(1.045);
  }

  .veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(12, 11, 10, .09), transparent 22%),
      linear-gradient(0deg, rgba(12, 11, 10, .18), transparent 26%);
    pointer-events: none;
  }

  .label {
    position: absolute;
    right: 14px;
    bottom: 12px;
    padding: 6px 9px;
    border: 1px solid rgba(255, 255, 255, .45);
    border-radius: 999px;
    background: rgba(16, 15, 14, .42);
    color: rgba(255, 255, 255, .88);
    backdrop-filter: blur(8px);
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: .11em;
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: reduce) {
    img {
      transition: none;
    }
  }
</style>

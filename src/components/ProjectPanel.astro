---
import { projects } from "../data/profile";

interface Props {
  index: number;
  animate?: boolean;
  /**
   * 動画を持つ案件でも静止画で描く。
   * 帯（WorkStrip）は継ぎ目のないループのため同じ並びを2回描くので、
   * そのまま動画を載せると同じ動画が4本同時に走る。帯はポスターで足りる。
   */
  still?: boolean;
}

const { index, animate = true, still = !animate } = Astro.props;
const project = projects[index];
const video = still ? null : project.video;
---

<div class:list={["panel", `panel--${project.id}`, animate && "panel--animate"]}>
  {
    video ? (
      <div class="actual-product">
        <div class="actual-copy" aria-hidden="true">
          <span>GENERATIVE VIDEO</span>
          <b>Made without<br />a camera.</b>
        </div>
        <div class="device">
          {/*
            preload="none" とポスターで、見えるまで 2MB を取りに行かせない。
            再生・停止は下の script が交差監視で行う。
            muted / playsinline はモバイルの自動再生に必須。
          */}
          <video
            data-project-video
            src={video.src}
            poster={video.poster}
            width="540"
            height="960"
            muted
            loop
            playsinline
            preload="none"
            aria-label={project.imageAlt.ja}
          />
        </div>
      </div>
    ) : project.id === "annoscene" ? (
      <div class="actual-product">
        <div class="actual-copy" aria-hidden="true">
          <span>ACTUAL PRODUCT / iOS</span>
          <b>Journey<br />playback.</b>
          <i>VANCOUVER → BANFF</i>
        </div>
        <div class="device">
          <img
            src={project.image}
            alt={project.imageAlt.ja}
            loading="lazy"
            decoding="async"
            width="540"
            height="1094"
          />
        </div>
      </div>
    ) : (
      <picture>
        <img
          src={project.image}
          alt={project.imageAlt.ja}
          loading="lazy"
          decoding="async"
          width="1536"
          height="1024"
        />
      </picture>
    )
  }
  <span class="veil" aria-hidden="true"></span>
  <span class="label">
    {
      video ? (
        <>
          <span class="ja">生成AI</span>
          <span class="en">AI generated</span>
        </>
      ) : project.id === "annoscene" ? (
        <>
          <span class="ja">実画面</span>
          <span class="en">Actual UI</span>
        </>
      ) : (
        <>
          <span class="ja">画面イメージ</span>
          <span class="en">Concept visual</span>
        </>
      )
    }
  </span>
</div>

<script>
  /*
   * 画面に入ったときだけ再生する。止まっている動画に帯域も電池も使わせない。
   * 動きを減らす設定ではポスターのまま置く（再生しない）。
   */
  const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const videos = [...document.querySelectorAll<HTMLVideoElement>("[data-project-video]")];

  if (videos.length && !reduced) {
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        const el = entry.target as HTMLVideoElement;
        if (entry.isIntersecting) {
          if (el.preload === "none") el.preload = "auto";
          el.play().catch(() => {
            /* 自動再生が拒否される環境ではポスターのまま。表示は壊れない */
          });
        } else {
          el.pause();
        }
      }
    }, { threshold: 0.25 });

    for (const video of videos) io.observe(video);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) for (const video of videos) video.pause();
    });
  }
</script>

<style>
  .panel {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: #e9e5df;
  }

  picture,
  img {
    width: 100%;
    height: 100%;
  }

  picture {
    display: block;
  }

  img {
    display: block;
    object-fit: cover;
    transition: transform 900ms var(--ease-out);
  }

  .actual-product {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background:
      radial-gradient(circle at 72% 36%, rgba(84, 120, 222, .28), transparent 34%),
      linear-gradient(145deg, #111318, #1d2331);
    color: #f6f4ef;
  }

  .actual-product::before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: .22;
    background-image:
      linear-gradient(rgba(255,255,255,.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.08) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: linear-gradient(90deg, #000, transparent 74%);
  }

  .actual-copy {
    position: absolute;
    z-index: 2;
    left: 7%;
    top: 17%;
  }

  .actual-copy span,
  .actual-copy i {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(9px, .72vw, 11px);
    font-style: normal;
    letter-spacing: .13em;
    color: rgba(246,244,239,.52);
  }

  .actual-copy b {
    display: block;
    margin-block: 18px 30px;
    font-size: clamp(27px, 4.2vw, 62px);
    font-weight: 530;
    line-height: .94;
    letter-spacing: -.055em;
  }

  .device {
    position: absolute;
    z-index: 2;
    top: 7%;
    right: 10%;
    width: min(31%, 280px);
    aspect-ratio: 540 / 1094;
    padding: 7px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.24);
    border-radius: 12% / 6%;
    background: #060708;
    box-shadow: 0 34px 70px rgba(0,0,0,.42);
    rotate: 5deg;
  }

  .device img,
  .device video {
    width: 100%;
    height: 100%;
    border-radius: 10% / 5%;
    object-fit: cover;
  }

  .panel--animate img {
    transform: scale(1.01);
  }

  .panel--annoscene.panel--animate .device {
    transition: transform 900ms var(--ease-out);
  }

  :global(.project a:hover) .panel--animate img {
    transform: scale(1.045);
  }

  :global(.project a:hover) .panel--annoscene.panel--animate .device {
    transform: translateY(-8px) rotate(-1deg);
  }

  .veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(12, 11, 10, .09), transparent 22%),
      linear-gradient(0deg, rgba(12, 11, 10, .18), transparent 26%);
    pointer-events: none;
  }

  .label {
    position: absolute;
    right: 14px;
    bottom: 12px;
    padding: 6px 9px;
    border: 1px solid rgba(255, 255, 255, .45);
    border-radius: 999px;
    background: rgba(16, 15, 14, .42);
    color: rgba(255, 255, 255, .88);
    backdrop-filter: blur(8px);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: .11em;
    text-transform: uppercase;
  }

  /*
   * 端末枠の既定は AnnoScene の実画面（540x1094）に合わせてあり、
   * 下辺からはみ出させる意匠になっている。動画は 9:16 で切れると
   * 中身が読めないので、この案件だけ枠内に収める。
   */
  .panel--ai-video .device {
    top: 8%;
    right: 7%;
    width: min(26%, 224px);
    aspect-ratio: 9 / 16;
  }

  @media (max-width: 720px) {
    /* 狭い画面では添え書きを畳んで、動画そのものを大きく見せる */
    .panel--ai-video .actual-copy {
      display: none;
    }

    /* 端末を中央に置くので、ラベルは右から左へ逃がす */
    .panel--ai-video .label {
      right: auto;
      left: 12px;
    }

    .panel--ai-video .device {
      top: 50%;
      right: 50%;
      width: 40%;
      translate: 50% -50%;
      rotate: 0deg;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    img {
      transition: none;
    }
  }
</style>

---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import ToolUniverse from "../components/ToolUniverse.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import Stats from "../components/Stats.astro";
import Work from "../components/Work.astro";
import Ethos from "../components/Ethos.astro";
import Skills from "../components/Skills.astro";
import Lab from "../components/Lab.astro";
import Path from "../components/Path.astro";
import Process from "../components/Process.astro";
import Services from "../components/Services.astro";
import Play from "../components/Play.astro";
import Contact from "../components/Contact.astro";
import { site } from "../data/profile";
---

<Base title={site.title} description={site.description.ja}>
  <Nav />
  <main id="main">
    <ToolUniverse />
    <Hero />
    <Marquee />
    <Stats />
    <Work />
    <Lab />
    <Ethos />
    <Skills />
    <Process />
    <Path />
    <Play />
    <Services />
    <Contact />
  </main>
</Base>

<script>
  import { initLang } from "../scripts/lang";
  import { initReveal, initCounters } from "../scripts/reveal";
  import { initTilt } from "../scripts/tilt";

  initLang();
  initReveal();
  initCounters();
  initTilt();
</script>
